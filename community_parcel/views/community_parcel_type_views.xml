<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_parcel_type_form" model="ir.ui.view">
        <field name="name">community.parcel.type.form</field>
        <field name="model">community.parcel.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_parcel_type_list" model="ir.ui.view">
        <field name="name">community.parcel.type.list</field>
        <field name="model">community.parcel.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="action_parcel_type" model="ir.actions.act_window">
        <field name="name">包裹類型</field>
        <field name="res_model">community.parcel.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
