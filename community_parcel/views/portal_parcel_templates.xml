<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Portal My Home: add Parcel & Storage cards -->
    <template id="portal_my_home_parcel" name="Portal My Home - Parcel"
              inherit_id="portal.portal_my_home" priority="40">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <div class="o_portal_category row g-2 mt-3" id="portal_parcel_category">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/community_base/static/src/img/community-parcel.svg'"/>
                    <t t-set="title">包裹收件</t>
                    <t t-set="url" t-value="'/my/parcels'"/>
                    <t t-set="text">查看待取包裹</t>
                    <t t-set="placeholder_count" t-value="'parcel_count'"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/community_base/static/src/img/community-storage.svg'"/>
                    <t t-set="title">物品寄放</t>
                    <t t-set="url" t-value="'/my/storage'"/>
                    <t t-set="text">查看寄放物品狀態</t>
                    <t t-set="placeholder_count" t-value="'storage_count'"/>
                </t>
            </div>
        </xpath>
    </template>

    <!-- Portal Breadcrumb -->
    <template id="portal_breadcrumbs_parcel"
              inherit_id="portal.portal_breadcrumbs" priority="40">
        <xpath expr="//ol" position="inside">
            <li t-if="page_name == 'parcels'" class="breadcrumb-item active">包裹收件</li>
            <li t-if="page_name == 'storage'" class="breadcrumb-item active">物品寄放</li>
        </xpath>
    </template>

    <!-- Portal: Parcel List -->
    <template id="portal_parcels" name="My Parcels">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">包裹收件</t>
            </t>

            <!-- State filter tabs -->
            <div class="mb-3 d-flex flex-wrap gap-2">
                <a href="/my/parcels"
                   t-attf-class="btn btn-sm #{not current_state and 'btn-primary' or 'btn-outline-primary'}">
                    全部
                </a>
                <a href="/my/parcels?state=draft"
                   t-attf-class="btn btn-sm #{current_state == 'draft' and 'btn-primary' or 'btn-outline-primary'}">
                    待通知
                </a>
                <a href="/my/parcels?state=notified"
                   t-attf-class="btn btn-sm #{current_state == 'notified' and 'btn-primary' or 'btn-outline-primary'}">
                    已通知
                </a>
                <a href="/my/parcels?state=picked_up"
                   t-attf-class="btn btn-sm #{current_state == 'picked_up' and 'btn-primary' or 'btn-outline-primary'}">
                    已取件
                </a>
                <a href="/my/parcels?state=overdue"
                   t-attf-class="btn btn-sm #{current_state == 'overdue' and 'btn-danger' or 'btn-outline-danger'}">
                    逾期
                </a>
            </div>

            <div class="card" t-if="parcels">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>編號</th>
                                <th>條碼</th>
                                <th>戶號</th>
                                <th>類型</th>
                                <th>快遞業者</th>
                                <th>收件時間</th>
                                <th>狀態</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="parcels" t-as="p">
                                <td>
                                    <a t-attf-href="/my/parcels/#{p.id}"
                                       t-esc="p.name"/>
                                </td>
                                <td t-esc="p.barcode or '-'"/>
                                <td t-esc="p.unit_id.name"/>
                                <td t-esc="p.type_id.name or '-'"/>
                                <td t-esc="p.courier or '-'"/>
                                <td><span t-field="p.received_date"/></td>
                                <td>
                                    <span t-if="p.state == 'draft'"
                                          class="badge bg-secondary">待通知</span>
                                    <span t-if="p.state == 'notified'"
                                          class="badge bg-info">已通知</span>
                                    <span t-if="p.state == 'picked_up'"
                                          class="badge bg-success">已取件</span>
                                    <span t-if="p.state == 'returned'"
                                          class="badge bg-warning">已退回</span>
                                    <span t-if="p.state == 'overdue'"
                                          class="badge bg-danger">逾期</span>
                                    <span t-if="p.state == 'scrapped'"
                                          class="badge bg-dark">已報廢</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div t-else="" class="text-center py-4 text-muted">
                <p>目前沒有包裹記錄</p>
            </div>
        </t>
    </template>

    <!-- Portal: Parcel Detail -->
    <template id="portal_parcel_detail" name="Parcel Detail">
        <t t-call="portal.portal_layout">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <span t-esc="parcel.name"/>
                    </h5>
                    <span t-if="parcel.state == 'draft'"
                          class="badge bg-secondary">待通知</span>
                    <span t-if="parcel.state == 'notified'"
                          class="badge bg-info">已通知</span>
                    <span t-if="parcel.state == 'picked_up'"
                          class="badge bg-success">已取件</span>
                    <span t-if="parcel.state == 'returned'"
                          class="badge bg-warning">已退回</span>
                    <span t-if="parcel.state == 'overdue'"
                          class="badge bg-danger">逾期</span>
                    <span t-if="parcel.state == 'scrapped'"
                          class="badge bg-dark">已報廢</span>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-sm">
                                <tr>
                                    <th class="w-50">快遞條碼</th>
                                    <td t-esc="parcel.barcode or '-'"/>
                                </tr>
                                <tr>
                                    <th>戶號</th>
                                    <td t-esc="parcel.unit_id.name"/>
                                </tr>
                                <tr>
                                    <th>類型</th>
                                    <td t-esc="parcel.type_id.name or '-'"/>
                                </tr>
                                <tr>
                                    <th>快遞業者</th>
                                    <td t-esc="parcel.courier or '-'"/>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-sm">
                                <tr>
                                    <th class="w-50">收件時間</th>
                                    <td><span t-field="parcel.received_date"/></td>
                                </tr>
                                <tr>
                                    <th>通知時間</th>
                                    <td>
                                        <span t-if="parcel.notified_date" t-field="parcel.notified_date"/>
                                        <span t-else="">-</span>
                                    </td>
                                </tr>
                                <tr>
                                    <th>取件時間</th>
                                    <td>
                                        <span t-if="parcel.pickup_date" t-field="parcel.pickup_date"/>
                                        <span t-else="">-</span>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <div t-if="parcel.description">
                        <hr/>
                        <strong class="text-muted">物品敘述：</strong>
                        <p class="mt-2" style="white-space: pre-wrap;"
                           t-esc="parcel.description"/>
                    </div>
                </div>
            </div>

            <div class="mt-3" id="parcel_communication">
                <t t-call="portal.message_thread">
                    <t t-set="object" t-value="parcel"/>
                </t>
            </div>

            <div class="mt-3">
                <a href="/my/parcels" class="btn btn-secondary">
                    <i class="fa fa-arrow-left"/> 返回包裹列表
                </a>
            </div>
        </t>
    </template>

    <!-- Portal: Storage List -->
    <template id="portal_storage" name="My Storage Items">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">物品寄放</t>
            </t>

            <!-- State filter tabs -->
            <div class="mb-3 d-flex flex-wrap gap-2">
                <a href="/my/storage"
                   t-attf-class="btn btn-sm #{not current_state and 'btn-primary' or 'btn-outline-primary'}">
                    全部
                </a>
                <a href="/my/storage?state=pending"
                   t-attf-class="btn btn-sm #{current_state == 'pending' and 'btn-primary' or 'btn-outline-primary'}">
                    待接收
                </a>
                <a href="/my/storage?state=storing"
                   t-attf-class="btn btn-sm #{current_state == 'storing' and 'btn-primary' or 'btn-outline-primary'}">
                    保管中
                </a>
                <a href="/my/storage?state=ready"
                   t-attf-class="btn btn-sm #{current_state == 'ready' and 'btn-primary' or 'btn-outline-primary'}">
                    待取件
                </a>
                <a href="/my/storage?state=done"
                   t-attf-class="btn btn-sm #{current_state == 'done' and 'btn-primary' or 'btn-outline-primary'}">
                    已完成
                </a>
            </div>

            <div class="card" t-if="items">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>編號</th>
                                <th>戶號</th>
                                <th>類型</th>
                                <th>寄放位置</th>
                                <th>寄放時間</th>
                                <th>狀態</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="items" t-as="s">
                                <td>
                                    <a t-attf-href="/my/storage/#{s.id}"
                                       t-esc="s.name"/>
                                </td>
                                <td t-esc="s.unit_id.name"/>
                                <td t-esc="s.type_id.name or '-'"/>
                                <td t-esc="s.storage_location or '-'"/>
                                <td><span t-field="s.deposit_date"/></td>
                                <td>
                                    <span t-if="s.state == 'pending'"
                                          class="badge bg-secondary">待接收</span>
                                    <span t-if="s.state == 'storing'"
                                          class="badge bg-info">保管中</span>
                                    <span t-if="s.state == 'ready'"
                                          class="badge bg-warning">待取件</span>
                                    <span t-if="s.state == 'done'"
                                          class="badge bg-success">已完成</span>
                                    <span t-if="s.state == 'scrapped'"
                                          class="badge bg-dark">已報廢</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div t-else="" class="text-center py-4 text-muted">
                <p>目前沒有寄放物品記錄</p>
            </div>
        </t>
    </template>

    <!-- Portal: Storage Detail -->
    <template id="portal_storage_detail" name="Storage Item Detail">
        <t t-call="portal.portal_layout">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <span t-esc="item.name"/>
                    </h5>
                    <span t-if="item.state == 'pending'"
                          class="badge bg-secondary">待接收</span>
                    <span t-if="item.state == 'storing'"
                          class="badge bg-info">保管中</span>
                    <span t-if="item.state == 'ready'"
                          class="badge bg-warning">待取件</span>
                    <span t-if="item.state == 'done'"
                          class="badge bg-success">已完成</span>
                    <span t-if="item.state == 'scrapped'"
                          class="badge bg-dark">已報廢</span>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-sm">
                                <tr>
                                    <th class="w-50">戶號</th>
                                    <td t-esc="item.unit_id.name"/>
                                </tr>
                                <tr>
                                    <th>類型</th>
                                    <td t-esc="item.type_id.name or '-'"/>
                                </tr>
                                <tr>
                                    <th>取件人</th>
                                    <td t-esc="item.recipient_name or '-'"/>
                                </tr>
                                <tr>
                                    <th>寄放位置</th>
                                    <td t-esc="item.storage_location or '-'"/>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-sm">
                                <tr>
                                    <th class="w-50">寄放時間</th>
                                    <td><span t-field="item.deposit_date"/></td>
                                </tr>
                                <tr>
                                    <th>預計取件日</th>
                                    <td>
                                        <span t-if="item.expected_pickup" t-field="item.expected_pickup"/>
                                        <span t-else="">-</span>
                                    </td>
                                </tr>
                                <tr>
                                    <th>實際取件時間</th>
                                    <td>
                                        <span t-if="item.actual_pickup" t-field="item.actual_pickup"/>
                                        <span t-else="">-</span>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <div t-if="item.item_description">
                        <hr/>
                        <strong class="text-muted">物品敘述：</strong>
                        <p class="mt-2" style="white-space: pre-wrap;"
                           t-esc="item.item_description"/>
                    </div>
                </div>
            </div>

            <div class="mt-3" id="storage_communication">
                <t t-call="portal.message_thread">
                    <t t-set="object" t-value="item"/>
                </t>
            </div>

            <div class="mt-3">
                <a href="/my/storage" class="btn btn-secondary">
                    <i class="fa fa-arrow-left"/> 返回寄放列表
                </a>
            </div>
        </t>
    </template>

</odoo>
