<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ Dashboard Actions ═══ -->

    <!-- 今日到件 -->
    <record id="action_parcel_today" model="ir.actions.act_window">
        <field name="name">今日到件</field>
        <field name="res_model">community.parcel</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[
            ('received_date', '&gt;=', (context_today()).strftime('%Y-%m-%d 00:00:00')),
            ('received_date', '&lt;=', (context_today()).strftime('%Y-%m-%d 23:59:59'))
        ]</field>
        <field name="search_view_id" ref="community_parcel_view_search"/>
    </record>

    <!-- 未取件包裹 -->
    <record id="action_parcel_uncollected" model="ir.actions.act_window">
        <field name="name">未取件包裹</field>
        <field name="res_model">community.parcel</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('state', 'in', ('draft', 'notified', 'overdue'))]</field>
        <field name="search_view_id" ref="community_parcel_view_search"/>
    </record>

    <!-- 逾期包裹 -->
    <record id="action_parcel_overdue" model="ir.actions.act_window">
        <field name="name">逾期包裹</field>
        <field name="res_model">community.parcel</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('state', '=', 'overdue')]</field>
        <field name="search_view_id" ref="community_parcel_view_search"/>
    </record>
</odoo>
