<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 擴展聯絡人表單：加入戶號與社區住戶欄位 -->
    <record id="view_partner_form_inherit_community" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.community</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <field name="website" position="after">
                <field name="is_resident"/>
                <field name="unit_address" invisible="not is_resident"/>
            </field>
        </field>
    </record>

    <!-- 擴展聯絡人列表：顯示戶號 -->
    <record id="view_partner_tree_inherit_community" model="ir.ui.view">
        <field name="name">res.partner.tree.inherit.community</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <field name="phone" position="after">
                <field name="unit_address" optional="hide"/>
                <field name="is_resident" optional="hide"/>
            </field>
        </field>
    </record>
</odoo>
