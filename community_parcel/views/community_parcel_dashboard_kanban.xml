<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ Dashboard Kanban View (庫存概覽風格) ═══ -->
    <record id="community_parcel_dashboard_view_kanban" model="ir.ui.view">
        <field name="name">community.parcel.dashboard.kanban</field>
        <field name="model">community.parcel.dashboard</field>
        <field name="arch" type="xml">
            <kanban create="false" edit="false" delete="false"
                    group_create="false" group_edit="false" group_delete="false"
                    records_draggable="0" can_open="0"
                    class="o_kanban_dashboard">
                <field name="name"/>
                <field name="count"/>
                <field name="target_model"/>
                <field name="domain_filter"/>
                <field name="count_stat1"/>
                <field name="stat1_label"/>
                <field name="stat1_filter"/>
                <field name="count_stat2"/>
                <field name="stat2_label"/>
                <field name="stat2_filter"/>
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <div class="container o_kanban_card_content">
                            <!-- 標題 -->
                            <div class="row mb-3">
                                <div class="col-12">
                                    <a type="object" name="action_open">
                                        <field class="fw-bold fs-4" name="name"/>
                                    </a>
                                </div>
                            </div>
                            <!-- 左右佈局 -->
                            <div class="row">
                                <!-- 左側 Badge 按鈕 -->
                                <div class="col-6">
                                    <t t-if="record.count.raw_value > 0">
                                        <button class="btn btn-primary" name="action_open" type="object">
                                            <field name="count"/> 待處理
                                        </button>
                                    </t>
                                    <t t-else="">
                                        <button class="btn btn-light" name="action_open" type="object">
                                            開啟
                                        </button>
                                    </t>
                                </div>
                                <!-- 右側統計連結 -->
                                <div class="col-6">
                                    <div class="stock-overview-links">
                                        <t t-if="record.count_stat1.raw_value > 0">
                                            <div class="row">
                                                <a class="col-8 offset-4" type="object" name="action_open_stat1">
                                                    <field name="stat1_label"/>
                                                    <span class="float-end">
                                                        <field name="count_stat1"/>
                                                    </span>
                                                </a>
                                            </div>
                                        </t>
                                        <t t-if="record.count_stat2.raw_value > 0">
                                            <div class="row">
                                                <a class="col-8 offset-4" type="object" name="action_open_stat2">
                                                    <field name="stat2_label"/>
                                                    <span class="float-end">
                                                        <field name="count_stat2"/>
                                                    </span>
                                                </a>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══ Dashboard Action ═══ -->
    <record id="action_parcel_dashboard" model="ir.actions.act_window">
        <field name="name">工作台</field>
        <field name="res_model">community.parcel.dashboard</field>
        <field name="view_mode">kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                包裹管理工作台
            </p>
        </field>
    </record>
</odoo>
