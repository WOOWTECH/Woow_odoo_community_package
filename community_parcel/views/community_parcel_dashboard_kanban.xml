<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ Dashboard Kanban View ═══ -->
    <record id="community_parcel_dashboard_view_kanban" model="ir.ui.view">
        <field name="name">community.parcel.dashboard.kanban</field>
        <field name="model">community.parcel.dashboard</field>
        <field name="arch" type="xml">
            <kanban create="false" edit="false" delete="false"
                    group_create="false" group_edit="false" group_delete="false"
                    class="o_kanban_dashboard">
                <field name="name"/>
                <field name="count"/>
                <field name="target_model"/>
                <field name="domain_filter"/>
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <div class="container o_kanban_card_content">
                            <div class="row">
                                <div class="col-12">
                                    <strong class="o_kanban_record_title fs-5">
                                        <field name="name"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="row mt-2" t-if="record.count.raw_value > 0">
                                <div class="col-12">
                                    <span class="badge rounded-pill text-bg-primary fs-6">
                                        <field name="count"/> 待處理
                                    </span>
                                </div>
                            </div>
                            <div class="row mt-3">
                                <div class="col-12">
                                    <button name="action_open" type="object"
                                            class="btn btn-primary">
                                        開啟
                                    </button>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══ Dashboard Action ═══ -->
    <record id="action_parcel_dashboard" model="ir.actions.act_window">
        <field name="name">工作台</field>
        <field name="res_model">community.parcel.dashboard</field>
        <field name="view_mode">kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                包裹管理工作台
            </p>
        </field>
    </record>
</odoo>
