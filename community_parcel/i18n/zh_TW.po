#. module: community_parcel
#: model:mail.template,body_html:community_parcel.mail_template_parcel_overdue
msgid ""
"<div style=\"margin:0;padding:0;font-family:Arial,sans-serif;\">\n"
"    <p>親愛的 {{ object.unit_id.display_name }} 住戶您好，</p>\n"
"    <p>您有一件包裹已逾期未領取，請儘速至管理室取件：</p>\n"
"    <table style=\"border-collapse:collapse;margin:10px 0;\">\n"
"        <tr>\n"
"            <td style=\"padding:4px 12px 4px 0;font-weight:bold;\">編號</td>\n"
"            <td style=\"padding:4px 0;\">{{ object.name }}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding:4px 12px 4px 0;font-weight:bold;\">通知日期</td>\n"
"            <td style=\"padding:4px 0;\">{{ object.notified_date }}</td>\n"
"        </tr>\n"
"    </table>\n"
"    <p style=\"color:#d9534f;font-weight:bold;\">\n"
"        若逾期過久，管理室將進行退回處理，敬請留意。\n"
"    </p>\n"
"</div>\n"
"            "
msgstr ""
"<div style=\"margin:0;padding:0;font-family:Arial,sans-serif;\">\n"
"    <p>親愛的 {{ object.unit_id.display_name }} 住戶您好，</p>\n"
"    <p>您有一件包裹已逾期未領取，請儘速至管理室取件：</p>\n"
"    <table style=\"border-collapse:collapse;margin:10px 0;\">\n"
"        <tr>\n"
"            <td style=\"padding:4px 12px 4px 0;font-weight:bold;\">編號</td>\n"
"            <td style=\"padding:4px 0;\">{{ object.name }}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding:4px 12px 4px 0;font-weight:bold;\">通知日期</td>\n"
"            <td style=\"padding:4px 0;\">{{ object.notified_date }}</td>\n"
"        </tr>\n"
"    </table>\n"
"    <p style=\"color:#d9534f;font-weight:bold;\">\n"
"        若逾期過久，管理室將進行退回處理，敬請留意。\n"
"    </p>\n"
"</div>\n"
"            "

