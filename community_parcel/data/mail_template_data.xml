<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 包裹到件通知 -->
        <record id="mail_template_parcel_arrival" model="mail.template">
            <field name="name">包裹到件通知</field>
            <field name="model_id" ref="community_parcel.model_community_parcel"/>
            <field name="email_from">{{ (object.office_id.responsible_id.email or user.email_formatted) }}</field>
            <field name="email_to">{{ object.resident_id.email }}</field>
            <field name="subject">【社區通知】您有包裹到件 - {{ object.name }}</field>
            <field name="body_html"><![CDATA[
<div style="margin:0;padding:0;font-family:Arial,sans-serif;">
    <p>親愛的 {{ object.resident_id.name }} 您好，</p>
    <p>您有一件包裹已送達社區管理室，詳細資訊如下：</p>
    <table style="border-collapse:collapse;margin:10px 0;">
        <tr>
            <td style="padding:4px 12px 4px 0;font-weight:bold;">編號</td>
            <td style="padding:4px 0;">{{ object.name }}</td>
        </tr>
        <tr>
            <td style="padding:4px 12px 4px 0;font-weight:bold;">類型</td>
            <td style="padding:4px 0;">{{ object.parcel_type }}</td>
        </tr>
        <tr>
            <td style="padding:4px 12px 4px 0;font-weight:bold;">條碼</td>
            <td style="padding:4px 0;">{{ object.barcode or '無' }}</td>
        </tr>
        <tr>
            <td style="padding:4px 12px 4px 0;font-weight:bold;">收件時間</td>
            <td style="padding:4px 0;">{{ object.received_date }}</td>
        </tr>
        <tr>
            <td style="padding:4px 12px 4px 0;font-weight:bold;">管理室</td>
            <td style="padding:4px 0;">{{ object.office_id.name or '未指定' }}</td>
        </tr>
    </table>
    <p>請盡快至管理室領取，謝謝！</p>
</div>
            ]]></field>
            <field name="lang">{{ object.resident_id.lang }}</field>
            <field name="auto_delete" eval="True"/>
        </record>

        <!-- 包裹逾期提醒 -->
        <record id="mail_template_parcel_overdue" model="mail.template">
            <field name="name">包裹逾期提醒</field>
            <field name="model_id" ref="community_parcel.model_community_parcel"/>
            <field name="email_from">{{ (object.office_id.responsible_id.email or user.email_formatted) }}</field>
            <field name="email_to">{{ object.resident_id.email }}</field>
            <field name="subject">【社區提醒】您的包裹已逾期未取 - {{ object.name }}</field>
            <field name="body_html"><![CDATA[
<div style="margin:0;padding:0;font-family:Arial,sans-serif;">
    <p>親愛的 {{ object.resident_id.name }} 您好，</p>
    <p>您有一件包裹已逾期未領取，請儘速至管理室取件：</p>
    <table style="border-collapse:collapse;margin:10px 0;">
        <tr>
            <td style="padding:4px 12px 4px 0;font-weight:bold;">編號</td>
            <td style="padding:4px 0;">{{ object.name }}</td>
        </tr>
        <tr>
            <td style="padding:4px 12px 4px 0;font-weight:bold;">通知日期</td>
            <td style="padding:4px 0;">{{ object.notified_date }}</td>
        </tr>
    </table>
    <p style="color:#d9534f;font-weight:bold;">
        若逾期過久，管理室將進行退回處理，敬請留意。
    </p>
</div>
            ]]></field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
