<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_community_visitor" model="ir.module.category">
        <field name="name">社區訪客管理</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_guard" model="res.groups">
        <field name="name">警衛</field>
        <field name="category_id" ref="module_category_community_visitor"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_manager" model="res.groups">
        <field name="name">社區主任</field>
        <field name="category_id" ref="module_category_community_visitor"/>
        <field name="implied_ids" eval="[(4, ref('group_guard'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

</odoo>
