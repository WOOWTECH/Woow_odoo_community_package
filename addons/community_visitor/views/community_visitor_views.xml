<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_community_visitor_form" model="ir.ui.view">
        <field name="name">community.visitor.form</field>
        <field name="model">community.visitor</field>
        <field name="arch" type="xml">
            <form string="訪客">
                <header>
                    <button name="action_blacklist" type="object"
                            string="加入黑名單" class="btn-danger"
                            invisible="blacklisted"
                            groups="community_visitor.group_manager"/>
                    <button name="action_unblacklist" type="object"
                            string="移除黑名單" class="btn-warning"
                            invisible="not blacklisted"
                            groups="community_visitor.group_manager"/>
                </header>
                <sheet>
                    <div class="alert alert-danger" role="alert"
                         invisible="not blacklisted">
                        <strong><i class="fa fa-ban"/> 黑名單訪客</strong>
                        <span> -
                            <field name="blacklist_reason" nolabel="1"
                                   readonly="1"/>
                        </span>
                    </div>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_visits"
                                icon="fa-list">
                            <field name="visit_count" widget="statinfo"
                                   string="來訪次數"/>
                        </button>
                    </div>
                    <field name="photo" widget="image"
                           class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="訪客姓名"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="phone"/>
                            <field name="id_last4"/>
                            <field name="company"/>
                        </group>
                        <group>
                            <field name="last_visit"/>
                            <field name="blacklisted" invisible="1"/>
                            <field name="blacklist_date"
                                   invisible="not blacklisted"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="來訪記錄" name="visits">
                            <field name="visit_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="visit_type"/>
                                    <field name="unit_id"/>
                                    <field name="purpose_id"/>
                                    <field name="checkin_time"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_community_visitor_list" model="ir.ui.view">
        <field name="name">community.visitor.list</field>
        <field name="model">community.visitor</field>
        <field name="arch" type="xml">
            <list string="訪客"
                  decoration-danger="blacklisted == True">
                <field name="name"/>
                <field name="phone"/>
                <field name="company"/>
                <field name="visit_count"/>
                <field name="last_visit"/>
                <field name="blacklisted"/>
            </list>
        </field>
    </record>

    <record id="view_community_visitor_search" model="ir.ui.view">
        <field name="name">community.visitor.search</field>
        <field name="model">community.visitor</field>
        <field name="arch" type="xml">
            <search string="搜尋訪客">
                <field name="name"/>
                <field name="phone"/>
                <field name="company"/>
                <filter string="黑名單" name="blacklisted"
                        domain="[('blacklisted', '=', True)]"/>
                <filter string="非黑名單" name="not_blacklisted"
                        domain="[('blacklisted', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_community_visitor" model="ir.actions.act_window">
        <field name="name">訪客</field>
        <field name="res_model">community.visitor</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_not_blacklisted': 1}</field>
    </record>

</odoo>
