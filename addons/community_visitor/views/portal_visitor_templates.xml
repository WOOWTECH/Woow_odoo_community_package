<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Portal Home: REMOVED visitor/appointment sub-cards            -->
    <!-- Cards now only appear on /my/community hub                    -->
    <!-- ============================================================ -->

    <!-- ============================================================ -->
    <!-- Breadcrumbs: hierarchical (Home > 社區管理 > Section > Detail) -->
    <!-- ============================================================ -->
    <template id="portal_breadcrumbs_visitor"
              inherit_id="portal.portal_breadcrumbs" priority="35">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <!-- Visitors -->
            <li t-if="page_name in ('visitors', 'visit_detail')"
                class="breadcrumb-item">
                <a href="/my/community">社區管理</a>
            </li>
            <li t-if="page_name == 'visitors'" class="breadcrumb-item active">我的訪客</li>
            <li t-if="page_name == 'visit_detail'" class="breadcrumb-item">
                <a href="/my/visitors">我的訪客</a>
            </li>
            <li t-if="page_name == 'visit_detail'" class="breadcrumb-item active">
                <t t-esc="visit.name"/>
            </li>

            <!-- Appointments -->
            <li t-if="page_name in ('appointments', 'appointment_detail', 'appointment_new')"
                class="breadcrumb-item">
                <a href="/my/community">社區管理</a>
            </li>
            <li t-if="page_name == 'appointments'" class="breadcrumb-item active">我的預約</li>
            <li t-if="page_name in ('appointment_detail', 'appointment_new')" class="breadcrumb-item">
                <a href="/my/appointments">我的預約</a>
            </li>
            <li t-if="page_name == 'appointment_detail'" class="breadcrumb-item active">
                <t t-esc="appointment.name"/>
            </li>
            <li t-if="page_name == 'appointment_new'" class="breadcrumb-item active">新增預約</li>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Token error page (public, no portal layout needed)            -->
    <!-- ============================================================ -->
    <template id="portal_visitor_token_error" name="Visitor Token Error">
        <t t-call="portal.frontend_layout">
            <div class="container mt-4">
                <div class="alert alert-danger text-center" role="alert">
                    <h4><i class="fa fa-exclamation-triangle"/> 錯誤</h4>
                    <p t-esc="error"/>
                </div>
            </div>
        </t>
    </template>

    <!-- Token confirmation page (public) -->
    <template id="portal_visitor_confirm_page" name="Visitor Confirm Page">
        <t t-call="portal.frontend_layout">
            <div class="container mt-4">
                <div class="row justify-content-center">
                    <div class="col-md-8 col-lg-6">
                        <div class="card">
                            <div class="card-header bg-primary text-white text-center">
                                <h4 class="mb-0">訪客確認</h4>
                            </div>
                            <div class="card-body">
                                <table class="table table-borderless">
                                    <tr>
                                        <td class="text-muted">訪客姓名</td>
                                        <td><strong t-esc="visit.visitor_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">來訪目的</td>
                                        <td t-esc="visit.purpose_id.name"/>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">訪問戶號</td>
                                        <td t-esc="visit.unit_id.name"/>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">登記時間</td>
                                        <td><span t-field="visit.create_date"/></td>
                                    </tr>
                                </table>
                                <div class="text-center mt-4">
                                    <form t-attf-action="/visitor/confirm/#{token}/accept"
                                          method="post" class="d-inline">
                                        <input type="hidden" name="csrf_token"
                                               t-att-value="request.csrf_token()"/>
                                        <button type="submit"
                                                class="btn btn-success btn-lg mx-2"
                                                style="min-width: 120px;">
                                            <i class="fa fa-check"/> 確認放行
                                        </button>
                                    </form>
                                    <form t-attf-action="/visitor/confirm/#{token}/reject"
                                          method="post" class="d-inline">
                                        <input type="hidden" name="csrf_token"
                                               t-att-value="request.csrf_token()"/>
                                        <button type="submit"
                                                class="btn btn-danger btn-lg mx-2"
                                                style="min-width: 120px;">
                                            <i class="fa fa-times"/> 拒絕
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Confirmation result page (public) -->
    <template id="portal_visitor_confirm_result" name="Visitor Confirm Result">
        <t t-call="portal.frontend_layout">
            <div class="container mt-4">
                <div class="row justify-content-center">
                    <div class="col-md-8 col-lg-6 text-center">
                        <div t-if="result == 'confirmed'"
                             class="alert alert-success">
                            <h4><i class="fa fa-check-circle"/> 已確認放行</h4>
                            <p>訪客 <strong t-esc="visit.visitor_id.name"/> 已獲得放行許可。</p>
                        </div>
                        <div t-if="result == 'rejected'"
                             class="alert alert-danger">
                            <h4><i class="fa fa-times-circle"/> 已拒絕</h4>
                            <p>訪客 <strong t-esc="visit.visitor_id.name"/> 已被拒絕進入。</p>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Visitor List: portal_table + searchbar + pager                 -->
    <!-- ============================================================ -->
    <template id="portal_my_visitors" name="My Visitors">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">我的訪客</t>
            </t>

            <div t-if="not visits" class="alert alert-warning" role="alert">
                暫無訪客記錄
            </div>
            <t t-if="visits" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>編號</th>
                        <th>訪客</th>
                        <th>目的</th>
                        <th>戶號</th>
                        <th class="text-end">時間</th>
                        <th class="text-center">狀態</th>
                        <th class="text-center">操作</th>
                    </tr>
                </thead>
                <t t-foreach="visits" t-as="visit">
                    <tr>
                        <td>
                            <a t-attf-href="/my/visitors/#{visit.id}">
                                <t t-esc="visit.name"/>
                            </a>
                        </td>
                        <td><t t-esc="visit.visitor_id.name"/></td>
                        <td><t t-esc="visit.purpose_id.name"/></td>
                        <td><t t-esc="visit.unit_id.name"/></td>
                        <td class="text-end">
                            <span t-field="visit.create_date" t-options="{'widget': 'date'}"/>
                        </td>
                        <td class="text-center">
                            <span t-if="visit.state == 'pending_confirm'"
                                  class="badge rounded-pill text-bg-warning">待確認</span>
                            <span t-if="visit.state == 'confirmed'"
                                  class="badge rounded-pill text-bg-info">已確認</span>
                            <span t-if="visit.state == 'checked_in'"
                                  class="badge rounded-pill text-bg-success">已入場</span>
                            <span t-if="visit.state == 'checked_out'"
                                  class="badge rounded-pill text-bg-secondary">已離場</span>
                            <span t-if="visit.state == 'rejected'"
                                  class="badge rounded-pill text-bg-danger">已拒絕</span>
                            <span t-if="visit.state == 'timeout'"
                                  class="badge rounded-pill text-bg-dark">逾時</span>
                        </td>
                        <td class="text-center">
                            <t t-if="visit.state == 'pending_confirm' and visit.confirm_token">
                                <form t-attf-action="/visitor/confirm/#{visit.confirm_token}/accept"
                                      method="post" class="d-inline">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <button type="submit"
                                            class="btn btn-sm btn-success">放行</button>
                                </form>
                                <form t-attf-action="/visitor/confirm/#{visit.confirm_token}/reject"
                                      method="post" class="d-inline ms-1">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <button type="submit"
                                            class="btn btn-sm btn-danger">拒絕</button>
                                </form>
                            </t>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Appointment List: portal_table + searchbar + pager             -->
    <!-- ============================================================ -->
    <template id="portal_my_appointments" name="My Appointments">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">我的預約</t>
            </t>

            <div class="d-flex justify-content-end mb-3">
                <a href="/my/appointments/new" class="btn btn-primary">
                    <i class="fa fa-plus"/> 新增預約
                </a>
            </div>

            <div t-if="not appointments" class="alert alert-warning" role="alert">
                暫無預約記錄
            </div>
            <t t-if="appointments" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>編號</th>
                        <th>訪客</th>
                        <th>戶號</th>
                        <th>類型</th>
                        <th>有效期</th>
                        <th class="text-center">次數</th>
                        <th class="text-center">狀態</th>
                    </tr>
                </thead>
                <t t-foreach="appointments" t-as="apt">
                    <tr>
                        <td>
                            <a t-attf-href="/my/appointments/#{apt.id}">
                                <t t-esc="apt.name"/>
                            </a>
                        </td>
                        <td><t t-esc="apt.visitor_name"/></td>
                        <td><t t-esc="apt.unit_id.name"/></td>
                        <td><t t-esc="dict(apt._fields['appointment_type'].selection).get(apt.appointment_type, '')"/></td>
                        <td>
                            <span t-field="apt.valid_from" t-options="{'widget': 'date'}"/>
                            ~
                            <span t-field="apt.valid_until" t-options="{'widget': 'date'}"/>
                        </td>
                        <td class="text-center">
                            <t t-if="apt.max_entries == 0">無限</t>
                            <t t-else="">
                                <t t-esc="apt.used_entries"/>/<t t-esc="apt.max_entries"/>
                            </t>
                        </td>
                        <td class="text-center">
                            <span t-if="apt.state == 'active'"
                                  class="badge rounded-pill text-bg-success">有效</span>
                            <span t-if="apt.state == 'expired'"
                                  class="badge rounded-pill text-bg-secondary">已過期</span>
                            <span t-if="apt.state == 'cancelled'"
                                  class="badge rounded-pill text-bg-danger">已撤銷</span>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Appointment Detail: portal_sidebar layout                     -->
    <!-- ============================================================ -->
    <template id="portal_appointment_detail" name="Appointment Detail"
              inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <div class="row o_portal_appointment_sidebar">
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-4 col-xxl-3 d-print-none'"/>
                    <t t-set="entries">
                        <div class="d-flex flex-wrap flex-column gap-4">
                            <div class="d-flex align-items-center flex-grow-1 p-0"
                                 t-ignore="true" role="complementary">
                                <ul class="nav flex-column">
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#card_header">預約資訊</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#discussion_section">留言討論</a>
                                    </li>
                                </ul>
                            </div>
                            <div class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">狀態</small></h6>
                                <span t-if="appointment.state == 'active'"
                                      class="badge rounded-pill text-bg-success">有效</span>
                                <span t-if="appointment.state == 'expired'"
                                      class="badge rounded-pill text-bg-secondary">已過期</span>
                                <span t-if="appointment.state == 'cancelled'"
                                      class="badge rounded-pill text-bg-danger">已撤銷</span>
                            </div>
                            <div class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">剩餘次數</small></h6>
                                <div>
                                    <t t-if="appointment.max_entries == 0">無限</t>
                                    <t t-else="">
                                        <t t-esc="appointment.max_entries - appointment.used_entries"/>
                                        / <t t-esc="appointment.max_entries"/>
                                    </t>
                                </div>
                            </div>
                            <!-- QR Code in sidebar -->
                            <div t-if="appointment.qr_code" class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">QR Code</small></h6>
                                <img t-att-src="'data:image/png;base64,' + appointment.qr_code.decode('utf-8') if appointment.qr_code else ''"
                                     alt="QR Code" class="img-fluid" style="max-width: 160px;"/>
                            </div>
                            <!-- Cancel action -->
                            <div t-if="appointment.state == 'active'" class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">操作</small></h6>
                                <form t-attf-action="/my/appointments/#{appointment.id}/cancel"
                                      method="post"
                                      data-confirm="確定要撤銷此預約嗎？"
                                      onsubmit="return confirm(this.dataset.confirm);">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <button type="submit" class="btn btn-danger w-100">
                                        <i class="fa fa-times"/> 撤銷預約
                                    </button>
                                </form>
                            </div>
                        </div>
                    </t>
                </t>

                <div id="appointment_content" class="o_portal_content col-12 col-lg-8 col-xxl-9">
                    <div id="card">
                        <div id="card_header" data-anchor="true">
                            <div class="row justify-content-between mb-3">
                                <div class="col-12 col-md-9">
                                    <h3 class="my-0">
                                        <span t-field="appointment.name"/>
                                    </h3>
                                </div>
                                <div class="col-auto">
                                    <span t-if="appointment.state == 'active'"
                                          class="badge rounded-pill text-bg-success">有效</span>
                                    <span t-if="appointment.state == 'expired'"
                                          class="badge rounded-pill text-bg-secondary">已過期</span>
                                    <span t-if="appointment.state == 'cancelled'"
                                          class="badge rounded-pill text-bg-danger">已撤銷</span>
                                </div>
                            </div>
                        </div>
                        <div id="card_body">
                            <div t-if="error" class="alert alert-danger" role="alert">
                                <t t-esc="error"/>
                            </div>
                            <div class="row mb-4">
                                <div class="col-12 col-md-6">
                                    <div><strong>訪客姓名：</strong>
                                        <span t-esc="appointment.visitor_name"/></div>
                                    <div><strong>訪客電話：</strong>
                                        <span t-esc="appointment.visitor_phone"/></div>
                                    <div><strong>戶號：</strong>
                                        <span t-esc="appointment.unit_id.name"/></div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div><strong>有效期間：</strong>
                                        <span t-field="appointment.valid_from"/> ~
                                        <span t-field="appointment.valid_until"/></div>
                                    <div><strong>驗證碼：</strong>
                                        <span class="badge text-bg-dark fs-6"
                                              t-esc="appointment.access_token"/></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr/>
                    <div id="discussion_section" data-anchor="true">
                        <h3>留言討論</h3>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="appointment"/>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Visit Detail: portal_sidebar layout                           -->
    <!-- ============================================================ -->
    <template id="portal_visit_detail" name="Visit Detail"
              inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <div class="row o_portal_visit_sidebar">
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-4 col-xxl-3 d-print-none'"/>
                    <t t-set="entries">
                        <div class="d-flex flex-wrap flex-column gap-4">
                            <div class="d-flex align-items-center flex-grow-1 p-0"
                                 t-ignore="true" role="complementary">
                                <ul class="nav flex-column">
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#card_header">訪客資訊</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#discussion_section">留言討論</a>
                                    </li>
                                </ul>
                            </div>
                            <div class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">狀態</small></h6>
                                <span t-if="visit.state == 'draft'"
                                      class="badge rounded-pill text-bg-light">草稿</span>
                                <span t-if="visit.state == 'pending_confirm'"
                                      class="badge rounded-pill text-bg-warning">待確認</span>
                                <span t-if="visit.state == 'confirmed'"
                                      class="badge rounded-pill text-bg-info">已確認</span>
                                <span t-if="visit.state == 'checked_in'"
                                      class="badge rounded-pill text-bg-success">已入場</span>
                                <span t-if="visit.state == 'checked_out'"
                                      class="badge rounded-pill text-bg-secondary">已離場</span>
                                <span t-if="visit.state == 'rejected'"
                                      class="badge rounded-pill text-bg-danger">已拒絕</span>
                                <span t-if="visit.state == 'timeout'"
                                      class="badge rounded-pill text-bg-dark">逾時</span>
                            </div>
                            <!-- Confirm/Reject actions -->
                            <div t-if="visit.state == 'pending_confirm' and visit.confirm_token"
                                 class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">操作</small></h6>
                                <form t-attf-action="/visitor/confirm/#{visit.confirm_token}/accept"
                                      method="post">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <button type="submit" class="btn btn-success w-100">
                                        <i class="fa fa-check"/> 確認放行
                                    </button>
                                </form>
                                <form t-attf-action="/visitor/confirm/#{visit.confirm_token}/reject"
                                      method="post">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <button type="submit" class="btn btn-danger w-100">
                                        <i class="fa fa-times"/> 拒絕
                                    </button>
                                </form>
                            </div>
                        </div>
                    </t>
                </t>

                <div id="visit_content" class="o_portal_content col-12 col-lg-8 col-xxl-9">
                    <div id="card">
                        <div id="card_header" data-anchor="true">
                            <div class="row justify-content-between mb-3">
                                <div class="col-12 col-md-9">
                                    <h3 class="my-0">
                                        <span t-field="visit.name"/>
                                    </h3>
                                </div>
                            </div>
                        </div>
                        <div id="card_body">
                            <div class="row mb-4">
                                <div class="col-12 col-md-6">
                                    <div><strong>訪客姓名：</strong>
                                        <span t-esc="visit.visitor_id.name"/></div>
                                    <div t-if="visit.visitor_id.phone">
                                        <strong>訪客電話：</strong>
                                        <span t-esc="visit.visitor_id.phone"/></div>
                                    <div><strong>來訪目的：</strong>
                                        <span t-esc="visit.purpose_id.name"/></div>
                                    <div><strong>訪問類型：</strong>
                                        <span t-esc="dict(visit._fields['visit_type'].selection).get(visit.visit_type, '')"/></div>
                                    <div><strong>訪問戶號：</strong>
                                        <span t-esc="visit.unit_id.name"/></div>
                                    <div t-if="visit.visitor_id.vehicle_plate">
                                        <strong>車牌號碼：</strong>
                                        <span t-esc="visit.visitor_id.vehicle_plate"/></div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div><strong>登記時間：</strong>
                                        <span t-field="visit.create_date"/></div>
                                    <div t-if="visit.checkin_time">
                                        <strong>入場時間：</strong>
                                        <span t-field="visit.checkin_time"/></div>
                                    <div t-if="visit.checkout_time">
                                        <strong>離場時間：</strong>
                                        <span t-field="visit.checkout_time"/></div>
                                    <div t-if="visit.badge_id">
                                        <strong>訪客證：</strong>
                                        <span t-esc="visit.badge_id.name"/></div>
                                    <div t-if="visit.guard_in_id">
                                        <strong>入場警衛：</strong>
                                        <span t-esc="visit.guard_in_id.name"/></div>
                                </div>
                            </div>
                            <div t-if="visit.description">
                                <h5 class="mb-1">訪問敘述</h5>
                                <hr class="mt-1 mb-2"/>
                                <div class="py-1 px-2 bg-100 small"
                                     style="white-space: pre-wrap;"
                                     t-esc="visit.description"/>
                            </div>
                        </div>
                    </div>

                    <hr/>
                    <div id="discussion_section" data-anchor="true">
                        <h3>留言討論</h3>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="visit"/>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- New Appointment Form (kept as card layout)                    -->
    <!-- ============================================================ -->
    <template id="portal_appointment_new" name="New Appointment">
        <t t-call="portal.portal_layout">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">新增預約</h5>
                </div>
                <div class="card-body">
                    <div t-if="error" class="alert alert-danger" role="alert">
                        <t t-esc="error"/>
                    </div>
                    <form action="/my/appointments/create" method="post">
                        <input type="hidden" name="csrf_token"
                               t-att-value="request.csrf_token()"/>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">戶號</label>
                                <select name="unit_id" class="form-select"
                                        required="required">
                                    <option value="">請選擇...</option>
                                    <t t-foreach="units" t-as="unit">
                                        <option t-att-value="unit.id"
                                                t-esc="unit.name"/>
                                    </t>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">預約類型</label>
                                <select name="appointment_type"
                                        class="form-select">
                                    <option value="one_time">一次性</option>
                                    <option value="recurring">週期性</option>
                                    <option value="permanent">永久</option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">訪客姓名</label>
                                <input type="text" name="visitor_name"
                                       class="form-control"
                                       required="required"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">訪客電話</label>
                                <input type="tel" name="visitor_phone"
                                       class="form-control"
                                       required="required"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">有效起始</label>
                                <input type="datetime-local" name="valid_from"
                                       class="form-control"
                                       required="required"/>
                            </div>
                            <div class="col-md-6 mb-3" id="valid_until_group">
                                <label class="form-label">有效截止</label>
                                <input type="datetime-local" name="valid_until"
                                       class="form-control"
                                       id="valid_until_input"/>
                                <small class="text-muted">永久授權可不填</small>
                            </div>
                        </div>
                        <div class="row d-none" id="recurring_fields">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">授權星期</label>
                                <input type="text" name="recurring_days"
                                       class="form-control"
                                       placeholder="0,1,2,3,4"/>
                                <small class="text-muted">0=週一, 6=週日，以逗號分隔</small>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">每日起始時間</label>
                                <input type="time" name="recurring_from"
                                       class="form-control"/>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">每日截止時間</label>
                                <input type="time" name="recurring_until"
                                       class="form-control"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">最大入場次數</label>
                                <input type="number" name="max_entries"
                                       class="form-control" value="1"
                                       min="0"/>
                                <small class="text-muted">0 表示無限次</small>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">授權目的</label>
                            <textarea name="purpose" class="form-control"
                                      rows="2"></textarea>
                        </div>
                        <script>
                            document.addEventListener('DOMContentLoaded', function() {
                                var typeSelect = document.querySelector('select[name="appointment_type"]');
                                var validUntilInput = document.getElementById('valid_until_input');
                                var recurringFields = document.getElementById('recurring_fields');
                                if (typeSelect) {
                                    typeSelect.addEventListener('change', function() {
                                        if (this.value === 'permanent') {
                                            validUntilInput.removeAttribute('required');
                                        } else {
                                            validUntilInput.setAttribute('required', 'required');
                                        }
                                        if (this.value === 'recurring') {
                                            recurringFields.classList.remove('d-none');
                                        } else {
                                            recurringFields.classList.add('d-none');
                                        }
                                    });
                                    typeSelect.dispatchEvent(new Event('change'));
                                }
                                // Double-click protection
                                document.querySelectorAll('form').forEach(function(form) {
                                    form.addEventListener('submit', function() {
                                        var btn = form.querySelector('button[type="submit"]');
                                        if (btn) {
                                            btn.disabled = true;
                                            btn.textContent = btn.dataset.loadingText || '...';
                                        }
                                    });
                                });
                            });
                        </script>
                        <button type="submit" class="btn btn-primary"
                                data-loading-text="處理中...">
                            <i class="fa fa-plus"/> 建立預約
                        </button>
                        <a href="/my/appointments"
                           class="btn btn-secondary ms-2">取消</a>
                    </form>
                </div>
            </div>
        </t>
    </template>

</odoo>
