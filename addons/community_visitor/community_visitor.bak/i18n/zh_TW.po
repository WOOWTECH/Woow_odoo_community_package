"                                    <td style=\"padding: 8px 0;\">{{ object.purpose_id.name }}</td>\n"
"                                </tr>\n"
"                                <tr>\n"
"                                    <td style=\"padding: 8px 0; color: #666;\">訪問戶號：</td>\n"
"                                    <td style=\"padding: 8px 0;\">{{ object.unit_id.name }}</td>\n"
"                                </tr>\n"
"                                <tr>\n"
"                                    <td style=\"padding: 8px 0; color: #666;\">登記時間：</td>\n"
"                                    <td style=\"padding: 8px 0;\">{{ object.create_date }}</td>\n"
"                                </tr>\n"
"                            </table>\n"
"                            <div style=\"text-align: center; margin: 30px 0;\">\n"
"                                <a href=\"%7B%7B%20ctx.get('confirm_url',%20'#')%20%7D%7D\" style=\"background-color: #28a745; color: white; padding: 12px 40px;                                           text-decoration: none; border-radius: 5px; margin: 0 10px;                                           display: inline-block; font-size: 16px;\">\n"
