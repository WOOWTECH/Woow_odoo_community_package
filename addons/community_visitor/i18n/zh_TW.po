#. module: community_visitor
#: model:mail.template,body_html:community_visitor.mail_template_blacklist_alert
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <h3 style=\"color: #dc3545;\">黑名單訪客警示</h3>\n"
"    <p>以下黑名單訪客嘗試進入社區：</p>\n"
"    <table style=\"margin: 10px 0;\">\n"
"        <tr><td style=\"padding: 4px 8px; color: #666;\">姓名：</td>\n"
"            <td style=\"padding: 4px 8px;\"><strong>{{ object.name }}</strong></td></tr>\n"
"        <tr><td style=\"padding: 4px 8px; color: #666;\">電話：</td>\n"
"            <td style=\"padding: 4px 8px;\">{{ object.phone }}</td></tr>\n"
"        <tr><td style=\"padding: 4px 8px; color: #666;\">黑名單原因：</td>\n"
"            <td style=\"padding: 4px 8px;\">{{ object.blacklist_reason or '未說明' }}</td></tr>\n"
"        <tr><td style=\"padding: 4px 8px; color: #666;\">列入日期：</td>\n"
"            <td style=\"padding: 4px 8px;\">{{ object.blacklist_date }}</td></tr>\n"
"    </table>\n"
"    <p>請即時處理。</p>\n"
"</div>\n"
"        "
msgstr ""

#. module: community_visitor
#: model:mail.template,body_html:community_visitor.mail_template_appointment_visitor_arrived
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <p>您好，</p>\n"
"    <p>您的預約訪客 <strong>{{ object.visitor_id.name }}</strong> 已於\n"
"       <strong>{{ object.checkin_time }}</strong> 入場。</p>\n"
"    <table style=\"margin: 10px 0;\">\n"
"        <tr><td style=\"padding: 4px 8px; color: #666;\">戶號：</td>\n"
"            <td style=\"padding: 4px 8px;\">{{ object.unit_id.name }}</td></tr>\n"
"        <tr><td style=\"padding: 4px 8px; color: #666;\">目的：</td>\n"
"            <td style=\"padding: 4px 8px;\">{{ object.purpose_id.name }}</td></tr>\n"
"    </table>\n"
"</div>\n"
"        "
msgstr ""

#. module: community_visitor
#: model:mail.template,body_html:community_visitor.mail_template_visit_confirm_request
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <table style=\"width: 100%; background-color: #f5f5f5; padding: 20px;\">\n"
"        <tr>\n"
"            <td align=\"center\">\n"
"                <table style=\"width: 600px; background-color: white; border-radius: 8px; padding: 30px;\">\n"
"                    <tr>\n"
"                        <td>\n"
"                            <h2 style=\"color: #333;\">您有訪客等待確認</h2>\n"
"                            <table style=\"width: 100%; margin: 20px 0;\">\n"
"                                <tr>\n"
"                                    <td style=\"padding: 8px 0; color: #666;\">訪客姓名：</td>\n"
"                                    <td style=\"padding: 8px 0;\"><strong>{{ object.visitor_id.name }}</strong></td>\n"
"                                </tr>\n"
"                                <tr>\n"
"                                    <td style=\"padding: 8px 0; color: #666;\">來訪目的：</td>\n"
"                                    <td style=\"padding: 8px 0;\">{{ object.purpose_id.name }}</td>\n"
"                                </tr>\n"
"                                <tr>\n"
"                                    <td style=\"padding: 8px 0; color: #666;\">訪問戶號：</td>\n"
"                                    <td style=\"padding: 8px 0;\">{{ object.unit_id.name }}</td>\n"
"                                </tr>\n"
"                                <tr>\n"
"                                    <td style=\"padding: 8px 0; color: #666;\">登記時間：</td>\n"
"                                    <td style=\"padding: 8px 0;\">{{ object.create_date }}</td>\n"
"                                </tr>\n"
"                            </table>\n"
"                            <div style=\"text-align: center; margin: 30px 0;\">\n"
"                                <a href=\"%7B%7B%20ctx.get('confirm_url',%20'#')%20%7D%7D\" style=\"background-color: #28a745; color: white; padding: 12px 40px;                                           text-decoration: none; border-radius: 5px; margin: 0 10px;                                           display: inline-block; font-size: 16px;\">\n"
"                                    確認放行\n"
"                                </a>\n"
"                                <a href=\"%7B%7B%20ctx.get('reject_url',%20'#')%20%7D%7D\" style=\"background-color: #dc3545; color: white; padding: 12px 40px;                                           text-decoration: none; border-radius: 5px; margin: 0 10px;                                           display: inline-block; font-size: 16px;\">\n"
"                                    拒絕\n"
"                                </a>\n"
"                            </div>\n"
"                            <p style=\"color: #999; font-size: 12px; text-align: center;\">\n"
"                                此連結將在 20 分鐘後失效。\n"
"                            </p>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"            </td>\n"
"        </tr>\n"
"    </table>\n"
"</div>\n"
"        "
msgstr ""

