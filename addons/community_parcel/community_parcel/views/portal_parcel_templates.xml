<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Portal Home: REMOVED parcel/storage sub-cards                 -->
    <!-- Cards now only appear on /my/community hub                    -->
    <!-- ============================================================ -->

    <!-- ============================================================ -->
    <!-- Breadcrumbs: hierarchical (Home > Community Management > Section > Detail) -->
    <!-- ============================================================ -->
    <template id="portal_breadcrumbs_parcel"
              inherit_id="portal.portal_breadcrumbs" priority="40">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <!-- Parcels -->
            <li t-if="page_name in ('parcels', 'parcel_detail')"
                class="breadcrumb-item">
                <a href="/my/community">Community Management</a>
            </li>
            <li t-if="page_name == 'parcels'" class="breadcrumb-item active">Parcels</li>
            <li t-if="page_name == 'parcel_detail'" class="breadcrumb-item">
                <a href="/my/parcels">Parcels</a>
            </li>
            <li t-if="page_name == 'parcel_detail'" class="breadcrumb-item active">
                <t t-esc="parcel.name"/>
            </li>

            <!-- Storage -->
            <li t-if="page_name in ('storage', 'storage_detail', 'storage_new')"
                class="breadcrumb-item">
                <a href="/my/community">Community Management</a>
            </li>
            <li t-if="page_name == 'storage'" class="breadcrumb-item active">Storage</li>
            <li t-if="page_name in ('storage_detail', 'storage_new')" class="breadcrumb-item">
                <a href="/my/storage">Storage</a>
            </li>
            <li t-if="page_name == 'storage_detail'" class="breadcrumb-item active">
                <t t-esc="item.name"/>
            </li>
            <li t-if="page_name == 'storage_new'" class="breadcrumb-item active">New Storage</li>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Parcel List: portal_table + searchbar + pager                 -->
    <!-- ============================================================ -->
    <template id="portal_parcels" name="My Parcels">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Parcels</t>
            </t>

            <div t-if="not parcels" class="alert alert-warning" role="alert">
                No parcel records
            </div>
            <t t-if="parcels" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>No.</th>
                        <th>Barcode</th>
                        <th>Unit</th>
                        <th>Type</th>
                        <th>Courier</th>
                        <th class="text-end">Received</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <t t-foreach="parcels" t-as="p">
                    <tr>
                        <td>
                            <a t-attf-href="/my/parcels/#{p.id}">
                                <t t-esc="p.name"/>
                            </a>
                        </td>
                        <td><t t-esc="p.barcode or '-'"/></td>
                        <td><t t-esc="p.unit_id.name"/></td>
                        <td><t t-esc="p.type_id.name or '-'"/></td>
                        <td><t t-esc="p.courier or '-'"/></td>
                        <td class="text-end">
                            <span t-field="p.received_date" t-options="{'widget': 'date'}"/>
                        </td>
                        <td class="text-center">
                            <span t-if="p.state == 'draft'"
                                  class="badge rounded-pill text-bg-light">Pending Notify</span>
                            <span t-if="p.state == 'notified'"
                                  class="badge rounded-pill text-bg-info">Notified</span>
                            <span t-if="p.state == 'picked_up'"
                                  class="badge rounded-pill text-bg-success">Picked Up</span>
                            <span t-if="p.state == 'returned'"
                                  class="badge rounded-pill text-bg-secondary">Returned</span>
                            <span t-if="p.state == 'overdue'"
                                  class="badge rounded-pill text-bg-danger">Overdue</span>
                            <span t-if="p.state == 'scrapped'"
                                  class="badge rounded-pill text-bg-dark">Scrapped</span>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Parcel Detail: portal_sidebar layout                          -->
    <!-- ============================================================ -->
    <template id="portal_parcel_detail" name="Parcel Detail"
              inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <div class="row o_portal_parcel_sidebar">
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-4 col-xxl-3 d-print-none'"/>
                    <t t-set="entries">
                        <div class="d-flex flex-wrap flex-column gap-4">
                            <div class="d-flex align-items-center flex-grow-1 p-0"
                                 t-ignore="true" role="complementary">
                                <ul class="nav flex-column">
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#card_header">Parcel Info</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#discussion_section">History</a>
                                    </li>
                                </ul>
                            </div>
                            <div class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">Status</small></h6>
                                <span t-if="parcel.state == 'draft'"
                                      class="badge rounded-pill text-bg-light">Pending Notify</span>
                                <span t-if="parcel.state == 'notified'"
                                      class="badge rounded-pill text-bg-info">Notified</span>
                                <span t-if="parcel.state == 'picked_up'"
                                      class="badge rounded-pill text-bg-success">Picked Up</span>
                                <span t-if="parcel.state == 'returned'"
                                      class="badge rounded-pill text-bg-secondary">Returned</span>
                                <span t-if="parcel.state == 'overdue'"
                                      class="badge rounded-pill text-bg-danger">Overdue</span>
                                <span t-if="parcel.state == 'scrapped'"
                                      class="badge rounded-pill text-bg-dark">Scrapped</span>
                            </div>
                        </div>
                    </t>
                </t>

                <div id="parcel_content" class="o_portal_content col-12 col-lg-8 col-xxl-9">
                    <div id="card">
                        <div id="card_header" data-anchor="true">
                            <div class="row justify-content-between mb-3">
                                <div class="col-12 col-md-9">
                                    <h3 class="my-0">
                                        <span t-field="parcel.name"/>
                                    </h3>
                                </div>
                                <div class="col-auto">
                                    <span t-if="parcel.state == 'draft'"
                                          class="badge rounded-pill text-bg-light">Pending Notify</span>
                                    <span t-if="parcel.state == 'notified'"
                                          class="badge rounded-pill text-bg-info">Notified</span>
                                    <span t-if="parcel.state == 'picked_up'"
                                          class="badge rounded-pill text-bg-success">Picked Up</span>
                                    <span t-if="parcel.state == 'returned'"
                                          class="badge rounded-pill text-bg-secondary">Returned</span>
                                    <span t-if="parcel.state == 'overdue'"
                                          class="badge rounded-pill text-bg-danger">Overdue</span>
                                    <span t-if="parcel.state == 'scrapped'"
                                          class="badge rounded-pill text-bg-dark">Scrapped</span>
                                </div>
                            </div>
                        </div>
                        <div id="card_body">
                            <div class="row mb-4">
                                <div class="col-12 col-md-6">
                                    <div t-if="parcel.barcode"><strong>Barcode:</strong>
                                        <span t-esc="parcel.barcode"/></div>
                                    <div><strong>Unit:</strong>
                                        <span t-esc="parcel.unit_id.name"/></div>
                                    <div t-if="parcel.type_id"><strong>Type:</strong>
                                        <span t-esc="parcel.type_id.name"/></div>
                                    <div t-if="parcel.courier"><strong>Courier:</strong>
                                        <span t-esc="parcel.courier"/></div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div><strong>Received:</strong>
                                        <span t-field="parcel.received_date"/></div>
                                    <div t-if="parcel.notified_date"><strong>Notified:</strong>
                                        <span t-field="parcel.notified_date"/></div>
                                    <div t-if="parcel.pickup_date"><strong>Picked Up:</strong>
                                        <span t-field="parcel.pickup_date"/></div>
                                </div>
                            </div>
                            <div t-if="parcel.description">
                                <h5 class="mb-1">Item Description</h5>
                                <hr class="mt-1 mb-2"/>
                                <div class="py-1 px-2 bg-100 small"
                                     style="white-space: pre-wrap;"
                                     t-esc="parcel.description"/>
                            </div>
                        </div>
                    </div>

                    <hr/>
                    <div id="discussion_section" data-anchor="true">
                        <h3>History</h3>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="parcel"/>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Storage List: portal_table + searchbar + pager                -->
    <!-- ============================================================ -->
    <template id="portal_storage" name="My Storage Items">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Storage</t>
            </t>

            <div class="d-flex justify-content-end mb-3">
                <a href="/my/storage/new" class="btn btn-primary">
                    <i class="fa fa-plus"/> New Storage Request
                </a>
            </div>

            <div t-if="not items" class="alert alert-warning" role="alert">
                No storage records
            </div>
            <t t-if="items" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>No.</th>
                        <th>Unit</th>
                        <th>Type</th>
                        <th>Location</th>
                        <th class="text-end">Deposited</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <t t-foreach="items" t-as="s">
                    <tr>
                        <td>
                            <a t-attf-href="/my/storage/#{s.id}">
                                <t t-esc="s.name"/>
                            </a>
                        </td>
                        <td><t t-esc="s.unit_id.name"/></td>
                        <td><t t-esc="s.type_id.name or '-'"/></td>
                        <td><t t-esc="s.storage_location or '-'"/></td>
                        <td class="text-end">
                            <span t-field="s.deposit_date" t-options="{'widget': 'date'}"/>
                        </td>
                        <td class="text-center">
                            <span t-if="s.state == 'pending'"
                                  class="badge rounded-pill text-bg-warning">Pending Receipt</span>
                            <span t-if="s.state == 'storing'"
                                  class="badge rounded-pill text-bg-info">In Storage</span>
                            <span t-if="s.state == 'ready'"
                                  class="badge rounded-pill text-bg-primary">Ready for Pickup</span>
                            <span t-if="s.state == 'done'"
                                  class="badge rounded-pill text-bg-success">Completed</span>
                            <span t-if="s.state == 'scrapped'"
                                  class="badge rounded-pill text-bg-dark">Scrapped</span>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Storage Detail: portal_sidebar layout                         -->
    <!-- ============================================================ -->
    <template id="portal_storage_detail" name="Storage Item Detail"
              inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <div class="row o_portal_storage_sidebar">
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-4 col-xxl-3 d-print-none'"/>
                    <t t-set="entries">
                        <div class="d-flex flex-wrap flex-column gap-4">
                            <div class="d-flex align-items-center flex-grow-1 p-0"
                                 t-ignore="true" role="complementary">
                                <ul class="nav flex-column">
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#card_header">Storage Info</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#discussion_section">History</a>
                                    </li>
                                </ul>
                            </div>
                            <div class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">Status</small></h6>
                                <span t-if="item.state == 'pending'"
                                      class="badge rounded-pill text-bg-warning">Pending Receipt</span>
                                <span t-if="item.state == 'storing'"
                                      class="badge rounded-pill text-bg-info">In Storage</span>
                                <span t-if="item.state == 'ready'"
                                      class="badge rounded-pill text-bg-primary">Ready for Pickup</span>
                                <span t-if="item.state == 'done'"
                                      class="badge rounded-pill text-bg-success">Completed</span>
                                <span t-if="item.state == 'scrapped'"
                                      class="badge rounded-pill text-bg-dark">Scrapped</span>
                            </div>
                        </div>
                    </t>
                </t>

                <div id="storage_content" class="o_portal_content col-12 col-lg-8 col-xxl-9">
                    <div id="card">
                        <div id="card_header" data-anchor="true">
                            <div class="row justify-content-between mb-3">
                                <div class="col-12 col-md-9">
                                    <h3 class="my-0">
                                        <span t-field="item.name"/>
                                    </h3>
                                </div>
                                <div class="col-auto">
                                    <span t-if="item.state == 'pending'"
                                          class="badge rounded-pill text-bg-warning">Pending Receipt</span>
                                    <span t-if="item.state == 'storing'"
                                          class="badge rounded-pill text-bg-info">In Storage</span>
                                    <span t-if="item.state == 'ready'"
                                          class="badge rounded-pill text-bg-primary">Ready for Pickup</span>
                                    <span t-if="item.state == 'done'"
                                          class="badge rounded-pill text-bg-success">Completed</span>
                                    <span t-if="item.state == 'scrapped'"
                                          class="badge rounded-pill text-bg-dark">Scrapped</span>
                                </div>
                            </div>
                        </div>
                        <div id="card_body">
                            <div class="row mb-4">
                                <div class="col-12 col-md-6">
                                    <div><strong>Unit:</strong>
                                        <span t-esc="item.unit_id.name"/></div>
                                    <div t-if="item.type_id"><strong>Type:</strong>
                                        <span t-esc="item.type_id.name"/></div>
                                    <div t-if="item.recipient_name"><strong>Recipient:</strong>
                                        <span t-esc="item.recipient_name"/></div>
                                    <div t-if="item.storage_location"><strong>Location:</strong>
                                        <span t-esc="item.storage_location"/></div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div><strong>Deposited:</strong>
                                        <span t-field="item.deposit_date"/></div>
                                    <div t-if="item.expected_pickup"><strong>Expected Pickup:</strong>
                                        <span t-field="item.expected_pickup"/></div>
                                    <div t-if="item.actual_pickup"><strong>Actual Pickup:</strong>
                                        <span t-field="item.actual_pickup"/></div>
                                </div>
                            </div>
                            <div t-if="item.item_description">
                                <h5 class="mb-1">Item Description</h5>
                                <hr class="mt-1 mb-2"/>
                                <div class="py-1 px-2 bg-100 small"
                                     style="white-space: pre-wrap;"
                                     t-esc="item.item_description"/>
                            </div>
                        </div>
                    </div>

                    <hr/>
                    <div id="discussion_section" data-anchor="true">
                        <h3>History</h3>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="item"/>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- New Storage Request Form (card layout)                        -->
    <!-- ============================================================ -->
    <template id="portal_storage_new" name="New Storage Request">
        <t t-call="portal.portal_layout">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">New Storage Request</h5>
                </div>
                <div class="card-body">
                    <div t-if="error" class="alert alert-danger" role="alert">
                        <t t-esc="error"/>
                    </div>
                    <p class="text-muted">
                        Please fill in the following information to request storage. After submission, an administrator will confirm receipt.
                    </p>
                    <form action="/my/storage/create" method="post">
                        <input type="hidden" name="csrf_token"
                               t-att-value="request.csrf_token()"/>
                        <div class="mb-3">
                            <label class="form-label">Unit</label>
                            <select name="unit_id" class="form-select"
                                    required="required">
                                <option value="">Select unit</option>
                                <t t-foreach="units" t-as="unit">
                                    <option t-att-value="unit.id"
                                            t-esc="unit.name"/>
                                </t>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Storage Type</label>
                            <select name="type_id" class="form-select">
                                <option value="">Select type (optional)</option>
                                <t t-foreach="storage_types" t-as="stype">
                                    <option t-att-value="stype.id"
                                            t-esc="stype.name"/>
                                </t>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Item Description</label>
                            <textarea name="item_description" class="form-control"
                                      rows="4"
                                      placeholder="Please describe the stored items..."
                                      required="required"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Expected Pickup Date</label>
                            <input type="date" name="expected_pickup"
                                   class="form-control"/>
                        </div>
                        <script>
                            document.addEventListener('DOMContentLoaded', function() {
                                document.querySelectorAll('form').forEach(function(form) {
                                    form.addEventListener('submit', function() {
                                        var btn = form.querySelector('button[type="submit"]');
                                        if (btn) {
                                            btn.disabled = true;
                                            btn.textContent = btn.dataset.loadingText || '...';
                                        }
                                    });
                                });
                            });
                        </script>
                        <button type="submit" class="btn btn-primary"
                                data-loading-text="Processing...">
                            <i class="fa fa-paper-plane"/> Submit Request
                        </button>
                        <a href="/my/storage"
                           class="btn btn-secondary ms-2">Cancel</a>
                    </form>
                </div>
            </div>
        </t>
    </template>

</odoo>
