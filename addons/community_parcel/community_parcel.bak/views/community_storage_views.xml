<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ Form View ═══ -->
    <record id="community_storage_view_form" model="ir.ui.view">
        <field name="name">community.storage.form</field>
        <field name="model">community.storage</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_accept" string="受理"
                            type="object" class="btn-primary"
                            invisible="state != 'pending'"/>
                    <button name="action_ready" string="通知取件"
                            type="object" class="btn-primary"
                            invisible="state != 'storing'"/>
                    <button name="action_done" string="完成交付"
                            type="object" class="btn-primary"
                            invisible="state != 'ready'"/>
                    <button name="action_scrap" string="報廢"
                            type="object" class="btn-danger"
                            invisible="state == 'scrapped'"
                            confirm="確定要將此寄放物品報廢嗎？"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,storing,ready,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="寄放資訊">
                            <field name="unit_id"/>
                            <field name="recipient_name"/>
                            <field name="type_id"/>
                            <field name="office_id"/>
                            <field name="storage_location"/>
                        </group>
                        <group string="時間記錄">
                            <field name="deposit_date"/>
                            <field name="expected_pickup"/>
                            <field name="actual_pickup" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="物品敘述">
                            <field name="item_description" placeholder="物品敘述..."/>
                        </page>
                        <page string="內部備註">
                            <field name="internal_note" placeholder="內部備註..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══ List View ═══ -->
    <record id="community_storage_view_tree" model="ir.ui.view">
        <field name="name">community.storage.list</field>
        <field name="model">community.storage</field>
        <field name="arch" type="xml">
            <list decoration-muted="state in ('done', 'scrapped')"
                  multi_edit="1">
                <field name="name"/>
                <field name="unit_id"/>
                <field name="recipient_name"/>
                <field name="type_id" widget="badge"/>
                <field name="office_id"/>
                <field name="storage_location"/>
                <field name="deposit_date"/>
                <field name="expected_pickup"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'pending'"
                       decoration-warning="state == 'storing'"
                       decoration-success="state in ('ready', 'done')"
                       decoration-danger="state == 'scrapped'"/>
            </list>
        </field>
    </record>

    <!-- ═══ Kanban View ═══ -->
    <record id="community_storage_view_kanban" model="ir.ui.view">
        <field name="name">community.storage.kanban</field>
        <field name="model">community.storage</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="unit_id"/>
                <field name="recipient_name"/>
                <field name="type_id"/>
                <field name="state"/>
                <field name="storage_location"/>
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_top mb-1">
                            <strong><field name="name"/></strong>
                            <field name="type_id" widget="badge"/>
                        </div>
                        <div class="mb-1">
                            戶號: <field name="unit_id"/>
                        </div>
                        <div class="mb-1" t-if="record.recipient_name.raw_value">
                            取件人: <field name="recipient_name"/>
                        </div>
                        <div class="text-muted small" t-if="record.storage_location.raw_value">
                            位置: <field name="storage_location"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══ Search View ═══ -->
    <record id="community_storage_view_search" model="ir.ui.view">
        <field name="name">community.storage.search</field>
        <field name="model">community.storage</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="unit_id"/>
                <field name="recipient_name"/>
                <field name="item_description"/>
                <separator/>
                <filter string="待接收" name="filter_pending"
                        domain="[('state', '=', 'pending')]"/>
                <filter string="保管中" name="filter_storing"
                        domain="[('state', '=', 'storing')]"/>
                <filter string="待取件" name="filter_ready"
                        domain="[('state', '=', 'ready')]"/>
                <filter string="進行中" name="filter_active"
                        domain="[('state', 'in', ('pending', 'storing', 'ready'))]"/>
                <separator/>
                <group expand="0" string="分組">
                    <filter string="狀態" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="類型" name="group_type" context="{'group_by': 'type_id'}"/>
                    <filter string="管理室" name="group_office" context="{'group_by': 'office_id'}"/>
                    <filter string="寄放日" name="group_date" context="{'group_by': 'deposit_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ Action ═══ -->
    <record id="action_community_storage" model="ir.actions.act_window">
        <field name="name">所有寄放物品</field>
        <field name="res_model">community.storage</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="community_storage_view_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
    </record>
</odoo>
