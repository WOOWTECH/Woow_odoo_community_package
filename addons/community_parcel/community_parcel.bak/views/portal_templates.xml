<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Portal Breadcrumbs: parcel and storage pages                  -->
    <!-- ============================================================ -->

    <template id="portal_breadcrumbs_parcel"
              inherit_id="portal.portal_breadcrumbs" priority="36">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <!-- Community Hub link (parent) -->
            <li t-if="page_name in ('parcels', 'parcel_detail', 'storage', 'storage_detail', 'storage_new')"
                class="breadcrumb-item">
                <a href="/my/community">Community Management</a>
            </li>

            <!-- Parcels -->
            <li t-if="page_name == 'parcels'" class="breadcrumb-item active">Parcels</li>
            <li t-if="page_name == 'parcel_detail'" class="breadcrumb-item">
                <a href="/my/parcels">Parcels</a>
            </li>
            <li t-if="page_name == 'parcel_detail'" class="breadcrumb-item active">
                <t t-esc="parcel.name"/>
            </li>

            <!-- Storage -->
            <li t-if="page_name == 'storage'" class="breadcrumb-item active">Storage</li>
            <li t-if="page_name in ('storage_detail', 'storage_new')" class="breadcrumb-item">
                <a href="/my/storage">Storage</a>
            </li>
            <li t-if="page_name == 'storage_detail'" class="breadcrumb-item active">
                <t t-esc="storage.name"/>
            </li>
            <li t-if="page_name == 'storage_new'" class="breadcrumb-item active">New Storage Request</li>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Parcel List                                                   -->
    <!-- ============================================================ -->

    <template id="portal_my_parcels" name="My Parcels">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Parcels</t>
            </t>

            <div t-if="not parcels" class="alert alert-warning" role="alert">
                No parcel records
            </div>
            <t t-if="parcels" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>#</th>
                        <th>Tracking No.</th>
                        <th>Type</th>
                        <th>Unit</th>
                        <th class="text-end">Received</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <t t-foreach="parcels" t-as="parcel">
                    <tr>
                        <td>
                            <a t-attf-href="/my/parcels/#{parcel.id}">
                                <t t-esc="parcel.name"/>
                            </a>
                        </td>
                        <td><t t-esc="parcel.barcode"/></td>
                        <td><t t-esc="parcel.type_id.name"/></td>
                        <td><t t-esc="parcel.unit_id.name"/></td>
                        <td class="text-end">
                            <span t-field="parcel.received_date" t-options="{'widget': 'date'}"/>
                        </td>
                        <td class="text-center">
                            <span t-if="parcel.state == 'draft'"
                                  class="badge rounded-pill text-bg-light">Pending Notification</span>
                            <span t-if="parcel.state == 'notified'"
                                  class="badge rounded-pill text-bg-info">Notified</span>
                            <span t-if="parcel.state == 'picked_up'"
                                  class="badge rounded-pill text-bg-success">Picked Up</span>
                            <span t-if="parcel.state == 'returned'"
                                  class="badge rounded-pill text-bg-secondary">Returned</span>
                            <span t-if="parcel.state == 'overdue'"
                                  class="badge rounded-pill text-bg-danger">Overdue</span>
                            <span t-if="parcel.state == 'scrapped'"
                                  class="badge rounded-pill text-bg-dark">Scrapped</span>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Parcel Detail                                                 -->
    <!-- ============================================================ -->

    <template id="portal_parcel_detail" name="Parcel Detail"
              inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">

            <div class="row o_portal_parcel_sidebar">
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-4 col-xxl-3 d-print-none'"/>

                    <t t-set="entries">
                        <div class="d-flex flex-wrap flex-column gap-4">
                            <div class="d-flex align-items-center flex-grow-1 p-0" t-ignore="true" role="complementary">
                                <ul class="nav flex-column">
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#card_header">Details</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#discussion">History</a>
                                    </li>
                                </ul>
                            </div>

                            <div class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">Status</small></h6>
                                <span t-if="parcel.state == 'draft'"
                                      class="badge rounded-pill text-bg-light">Pending Notification</span>
                                <span t-if="parcel.state == 'notified'"
                                      class="badge rounded-pill text-bg-info">Notified</span>
                                <span t-if="parcel.state == 'picked_up'"
                                      class="badge rounded-pill text-bg-success">Picked Up</span>
                                <span t-if="parcel.state == 'returned'"
                                      class="badge rounded-pill text-bg-secondary">Returned</span>
                                <span t-if="parcel.state == 'overdue'"
                                      class="badge rounded-pill text-bg-danger">Overdue</span>
                                <span t-if="parcel.state == 'scrapped'"
                                      class="badge rounded-pill text-bg-dark">Scrapped</span>
                            </div>

                            <!-- Action: Pickup -->
                            <div t-if="parcel.state in ('notified', 'overdue')" class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">Actions</small></h6>
                                <form t-attf-action="/my/parcels/#{parcel.id}/pickup"
                                      method="post"
                                      onsubmit="return confirm('Confirm pickup?');">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <button type="submit" class="btn btn-success w-100">
                                        <i class="fa fa-check"/> Confirm Pickup
                                    </button>
                                </form>
                            </div>
                        </div>
                    </t>
                </t>

                <div id="parcel_content" class="o_portal_content col-12 col-lg-8 col-xxl-9">
                    <div id="card">
                        <div id="card_header" data-anchor="true">
                            <div class="row justify-content-between mb-3">
                                <div class="col-12 col-md-9">
                                    <h3 class="my-0">
                                        <span t-field="parcel.name"/>
                                    </h3>
                                </div>
                                <div class="col-auto">
                                    <span t-if="parcel.state == 'draft'"
                                          class="badge rounded-pill text-bg-light">Pending Notification</span>
                                    <span t-if="parcel.state == 'notified'"
                                          class="badge rounded-pill text-bg-info">Notified</span>
                                    <span t-if="parcel.state == 'picked_up'"
                                          class="badge rounded-pill text-bg-success">Picked Up</span>
                                    <span t-if="parcel.state == 'returned'"
                                          class="badge rounded-pill text-bg-secondary">Returned</span>
                                    <span t-if="parcel.state == 'overdue'"
                                          class="badge rounded-pill text-bg-danger">Overdue</span>
                                    <span t-if="parcel.state == 'scrapped'"
                                          class="badge rounded-pill text-bg-dark">Scrapped</span>
                                </div>
                            </div>
                        </div>
                        <div id="card_body">
                            <div class="row mb-4">
                                <div class="col-12 col-md-6">
                                    <div t-if="parcel.barcode"><strong>Tracking No.:</strong>
                                        <span t-esc="parcel.barcode"/>
                                    </div>
                                    <div t-if="parcel.type_id"><strong>Parcel Type:</strong>
                                        <span t-esc="parcel.type_id.name"/>
                                    </div>
                                    <div><strong>Unit:</strong>
                                        <span t-esc="parcel.unit_id.name"/>
                                    </div>
                                    <div><strong>Office:</strong>
                                        <span t-esc="parcel.office_id.name"/>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div><strong>Received:</strong>
                                        <span t-field="parcel.received_date"/>
                                    </div>
                                    <div t-if="parcel.notified_date"><strong>Notified:</strong>
                                        <span t-field="parcel.notified_date"/>
                                    </div>
                                    <div t-if="parcel.pickup_date"><strong>Picked Up:</strong>
                                        <span t-field="parcel.pickup_date"/>
                                    </div>
                                    <div t-if="parcel.picked_by"><strong>Picked Up By:</strong>
                                        <span t-esc="parcel.picked_by.name"/>
                                    </div>
                                </div>
                            </div>

                            <div t-if="parcel.description">
                                <h5 class="mb-1">Description</h5>
                                <hr class="mt-1 mb-2"/>
                                <div class="py-1 px-2 bg-100 small" style="white-space: pre-wrap;"
                                     t-esc="parcel.description"/>
                            </div>
                        </div>
                    </div>

                    <hr/>
                    <div id="discussion" data-anchor="true">
                        <h3>History</h3>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="parcel"/>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Storage List                                                  -->
    <!-- ============================================================ -->

    <template id="portal_my_storage" name="My Storage">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Storage</t>
            </t>

            <div class="d-flex justify-content-end mb-3">
                <a href="/my/storage/new" class="btn btn-secondary">
                    <i class="fa fa-plus"/> New Storage Request
                </a>
            </div>

            <div t-if="not storage_items" class="alert alert-warning" role="alert">
                No storage records
            </div>
            <t t-if="storage_items" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>#</th>
                        <th>Recipient</th>
                        <th>Type</th>
                        <th>Unit</th>
                        <th class="text-end">Deposited</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <t t-foreach="storage_items" t-as="item">
                    <tr>
                        <td>
                            <a t-attf-href="/my/storage/#{item.id}">
                                <t t-esc="item.name"/>
                            </a>
                        </td>
                        <td><t t-esc="item.recipient_name"/></td>
                        <td><t t-esc="item.type_id.name"/></td>
                        <td><t t-esc="item.unit_id.name"/></td>
                        <td class="text-end">
                            <span t-field="item.deposit_date" t-options="{'widget': 'date'}"/>
                        </td>
                        <td class="text-center">
                            <span t-if="item.state == 'pending'"
                                  class="badge rounded-pill text-bg-warning">Pending</span>
                            <span t-if="item.state == 'storing'"
                                  class="badge rounded-pill text-bg-info">Storing</span>
                            <span t-if="item.state == 'ready'"
                                  class="badge rounded-pill text-bg-primary">Ready for Pickup</span>
                            <span t-if="item.state == 'done'"
                                  class="badge rounded-pill text-bg-success">Completed</span>
                            <span t-if="item.state == 'scrapped'"
                                  class="badge rounded-pill text-bg-dark">Scrapped</span>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Storage Detail                                                -->
    <!-- ============================================================ -->

    <template id="portal_storage_detail" name="Storage Detail"
              inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">

            <div class="row o_portal_storage_sidebar">
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-4 col-xxl-3 d-print-none'"/>

                    <t t-set="entries">
                        <div class="d-flex flex-wrap flex-column gap-4">
                            <div class="d-flex align-items-center flex-grow-1 p-0" t-ignore="true" role="complementary">
                                <ul class="nav flex-column">
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#card_header">Details</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#discussion">History</a>
                                    </li>
                                </ul>
                            </div>

                            <div class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">Status</small></h6>
                                <span t-if="storage.state == 'pending'"
                                      class="badge rounded-pill text-bg-warning">Pending</span>
                                <span t-if="storage.state == 'storing'"
                                      class="badge rounded-pill text-bg-info">Storing</span>
                                <span t-if="storage.state == 'ready'"
                                      class="badge rounded-pill text-bg-primary">Ready for Pickup</span>
                                <span t-if="storage.state == 'done'"
                                      class="badge rounded-pill text-bg-success">Completed</span>
                                <span t-if="storage.state == 'scrapped'"
                                      class="badge rounded-pill text-bg-dark">Scrapped</span>
                            </div>

                            <!-- Action: Pickup -->
                            <div t-if="storage.state == 'ready'" class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">Actions</small></h6>
                                <form t-attf-action="/my/storage/#{storage.id}/pickup"
                                      method="post"
                                      onsubmit="return confirm('Confirm pickup?');">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <button type="submit" class="btn btn-success w-100">
                                        <i class="fa fa-check"/> Confirm Pickup
                                    </button>
                                </form>
                            </div>
                        </div>
                    </t>
                </t>

                <div id="storage_content" class="o_portal_content col-12 col-lg-8 col-xxl-9">
                    <div id="card">
                        <div id="card_header" data-anchor="true">
                            <div class="row justify-content-between mb-3">
                                <div class="col-12 col-md-9">
                                    <h3 class="my-0">
                                        <span t-field="storage.name"/>
                                    </h3>
                                </div>
                                <div class="col-auto">
                                    <span t-if="storage.state == 'pending'"
                                          class="badge rounded-pill text-bg-warning">Pending</span>
                                    <span t-if="storage.state == 'storing'"
                                          class="badge rounded-pill text-bg-info">Storing</span>
                                    <span t-if="storage.state == 'ready'"
                                          class="badge rounded-pill text-bg-primary">Ready for Pickup</span>
                                    <span t-if="storage.state == 'done'"
                                          class="badge rounded-pill text-bg-success">Completed</span>
                                    <span t-if="storage.state == 'scrapped'"
                                          class="badge rounded-pill text-bg-dark">Scrapped</span>
                                </div>
                            </div>
                        </div>
                        <div id="card_body">
                            <div class="row mb-4">
                                <div class="col-12 col-md-6">
                                    <div t-if="storage.recipient_name"><strong>Recipient:</strong>
                                        <span t-esc="storage.recipient_name"/>
                                    </div>
                                    <div t-if="storage.type_id"><strong>Storage Type:</strong>
                                        <span t-esc="storage.type_id.name"/>
                                    </div>
                                    <div><strong>Unit:</strong>
                                        <span t-esc="storage.unit_id.name"/>
                                    </div>
                                    <div><strong>Office:</strong>
                                        <span t-esc="storage.office_id.name"/>
                                    </div>
                                    <div t-if="storage.storage_location"><strong>Storage Location:</strong>
                                        <span t-esc="storage.storage_location"/>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div><strong>Deposited:</strong>
                                        <span t-field="storage.deposit_date"/>
                                    </div>
                                    <div t-if="storage.expected_pickup"><strong>Expected Pickup:</strong>
                                        <span t-field="storage.expected_pickup"/>
                                    </div>
                                    <div t-if="storage.actual_pickup"><strong>Actual Pickup:</strong>
                                        <span t-field="storage.actual_pickup"/>
                                    </div>
                                </div>
                            </div>

                            <div t-if="storage.item_description">
                                <h5 class="mb-1">Item Description</h5>
                                <hr class="mt-1 mb-2"/>
                                <div class="py-1 px-2 bg-100 small" style="white-space: pre-wrap;"
                                     t-esc="storage.item_description"/>
                            </div>
                        </div>
                    </div>

                    <hr/>
                    <div id="discussion" data-anchor="true">
                        <h3>History</h3>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="storage"/>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- New Storage Form                                              -->
    <!-- ============================================================ -->

    <template id="portal_storage_new" name="New Storage Request">
        <t t-call="portal.portal_layout">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">New Storage Request</h5>
                </div>
                <div class="card-body">
                    <form action="/my/storage/create" method="post">
                        <input type="hidden" name="csrf_token"
                               t-att-value="request.csrf_token()"/>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Unit <span class="text-danger">*</span></label>
                                <select name="unit_id" class="form-select" required="required">
                                    <option value="">Select unit</option>
                                    <t t-foreach="units" t-as="unit">
                                        <option t-att-value="unit.id" t-esc="unit.name"/>
                                    </t>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Storage Type</label>
                                <select name="type_id" class="form-select">
                                    <option value="0">Select...</option>
                                    <t t-foreach="storage_types" t-as="stype">
                                        <option t-att-value="stype.id" t-esc="stype.name"/>
                                    </t>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Recipient <span class="text-danger">*</span></label>
                                <input type="text" name="recipient_name"
                                       class="form-control" required="required"
                                       placeholder="Enter recipient name"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Expected Pickup Date</label>
                                <input type="date" name="expected_pickup" class="form-control"/>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Item Description</label>
                            <textarea name="item_description" class="form-control" rows="3"
                                      placeholder="Describe the items to store..."/>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-secondary">
                                <i class="fa fa-plus"/> Submit Request
                            </button>
                            <a href="/my/storage" class="btn btn-light">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </t>
    </template>

</odoo>
