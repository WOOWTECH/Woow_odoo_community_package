<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_inherit_community" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.community</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='internal_notes']" position="before">
                <page string="社區資訊" name="community_info">
                    <group>
                        <field name="is_resident"/>
                    </group>
                    <group string="所屬戶號" invisible="not is_resident">
                        <field name="unit_ids" nolabel="1">
                            <list>
                                <field name="name"/>
                                <field name="building"/>
                                <field name="floor"/>
                                <field name="number"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
