<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Root menu -->
    <menuitem id="menu_community_root"
              name="社區管理"
              web_icon="community_base,static/description/icon.png"
              sequence="100"/>

    <!-- Announcement sub-menu -->
    <menuitem id="menu_community_announcement_root"
              name="公布欄"
              parent="menu_community_root"
              sequence="10"/>

    <menuitem id="menu_community_announcement_list"
              name="公告列表"
              parent="menu_community_announcement_root"
              action="action_community_announcement"
              sequence="10"/>

    <menuitem id="menu_community_announcement_category"
              name="公告分類"
              parent="menu_community_announcement_root"
              action="action_announcement_category"
              sequence="20"/>

    <!-- Feedback sub-menu -->
    <menuitem id="menu_community_feedback_root"
              name="意見反映"
              parent="menu_community_root"
              sequence="20"/>

    <menuitem id="menu_community_feedback_list"
              name="意見列表"
              parent="menu_community_feedback_root"
              action="action_community_feedback"
              sequence="10"/>

    <menuitem id="menu_community_feedback_category"
              name="意見分類"
              parent="menu_community_feedback_root"
              action="action_feedback_category"
              sequence="20"/>

    <!-- Configuration sub-menu -->
    <menuitem id="menu_community_config"
              name="基礎設定"
              parent="menu_community_root"
              sequence="90"/>

    <menuitem id="menu_community_unit"
              name="戶號"
              parent="menu_community_config"
              action="action_community_unit"
              sequence="10"/>

    <menuitem id="menu_community_office"
              name="管理室"
              parent="menu_community_config"
              action="action_community_office"
              sequence="20"/>

</odoo>
