<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_community_office_form" model="ir.ui.view">
        <field name="name">community.office.form</field>
        <field name="model">community.office</field>
        <field name="arch" type="xml">
            <form string="管理室">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="管理室名稱"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="building_name"/>
                        </group>
                        <group>
                            <field name="responsible_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="公告屬性定義" name="announcement_props">
                            <field name="announcement_properties_definition"/>
                        </page>
                        <page string="反映屬性定義" name="feedback_props">
                            <field name="feedback_properties_definition"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_community_office_list" model="ir.ui.view">
        <field name="name">community.office.list</field>
        <field name="model">community.office</field>
        <field name="arch" type="xml">
            <list string="管理室">
                <field name="name"/>
                <field name="building_name"/>
                <field name="responsible_id"/>
            </list>
        </field>
    </record>

    <record id="view_community_office_search" model="ir.ui.view">
        <field name="name">community.office.search</field>
        <field name="model">community.office</field>
        <field name="arch" type="xml">
            <search string="搜尋管理室">
                <field name="name"/>
                <field name="building_name"/>
            </search>
        </field>
    </record>

    <record id="action_community_office" model="ir.actions.act_window">
        <field name="name">管理室</field>
        <field name="res_model">community.office</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
