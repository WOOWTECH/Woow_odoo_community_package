<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_announcement_category_form" model="ir.ui.view">
        <field name="name">community.announcement.category.form</field>
        <field name="model">community.announcement.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_announcement_category_list" model="ir.ui.view">
        <field name="name">community.announcement.category.list</field>
        <field name="model">community.announcement.category</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="action_announcement_category" model="ir.actions.act_window">
        <field name="name">公告分類</field>
        <field name="res_model">community.announcement.category</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
