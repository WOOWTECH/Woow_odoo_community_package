<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Portal Home: single Community Management hub card             -->
    <!-- Uses portal_service_category like office_enhance              -->
    <!-- ============================================================ -->
    <template id="portal_my_home_community" name="Portal My Home - Community"
              inherit_id="portal.portal_my_home" customize_show="True" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_service_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_service_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/community_base/static/src/img/community-home.svg'"/>
                <t t-set="title">Community Management</t>
                <t t-set="text">Manage announcements, feedbacks, visitors and parcels</t>
                <t t-set="url" t-value="'/my/community'"/>
                <t t-set="placeholder_count" t-value="'community_count'"/>
                <t t-set="config_card" t-value="True"/>
            </t>
        </div>
    </template>

    <!-- ============================================================ -->
    <!-- Breadcrumbs: hierarchical (Home > Community Management > Section > Detail) -->
    <!-- ============================================================ -->
    <template id="portal_breadcrumbs_community"
              inherit_id="portal.portal_breadcrumbs" priority="30">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <!-- Hub page -->
            <li t-if="page_name == 'community'" class="breadcrumb-item active">Community Management</li>

            <!-- Announcements -->
            <li t-if="page_name in ('announcements', 'announcement_detail')"
                class="breadcrumb-item">
                <a href="/my/community">Community Management</a>
            </li>
            <li t-if="page_name == 'announcements'" class="breadcrumb-item active">Announcements</li>
            <li t-if="page_name == 'announcement_detail'" class="breadcrumb-item">
                <a href="/my/announcements">Announcements</a>
            </li>
            <li t-if="page_name == 'announcement_detail'" class="breadcrumb-item active">
                <t t-esc="announcement.name"/>
            </li>

            <!-- Feedbacks -->
            <li t-if="page_name in ('feedbacks', 'feedback_detail', 'feedback_new')"
                class="breadcrumb-item">
                <a href="/my/community">Community Management</a>
            </li>
            <li t-if="page_name == 'feedbacks'" class="breadcrumb-item active">Feedbacks</li>
            <li t-if="page_name in ('feedback_detail', 'feedback_new')" class="breadcrumb-item">
                <a href="/my/feedbacks">Feedbacks</a>
            </li>
            <li t-if="page_name == 'feedback_detail'" class="breadcrumb-item active">
                <t t-esc="feedback.name"/>
            </li>
            <li t-if="page_name == 'feedback_new'" class="breadcrumb-item active">New Feedback</li>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Hub Page: /my/community                                       -->
    <!-- Cards use portal.portal_docs_entry (same as office_enhance)   -->
    <!-- No title header                                               -->
    <!-- ============================================================ -->
    <template id="portal_my_community" name="Community Management Hub">
        <t t-call="portal.portal_layout">
            <div class="o_portal_community_hub">
                <div class="oe_structure" id="oe_structure_portal_community_1"/>
                <div class="o_portal_category row g-2 mt-3">
                    <!-- 1. Announcements -->
                    <t t-call="portal.portal_docs_entry">
                        <t t-set="icon" t-value="'/community_base/static/src/img/community-announcement.svg'"/>
                        <t t-set="title">Announcements</t>
                        <t t-set="text">Browse community bulletin board</t>
                        <t t-set="url" t-value="'/my/announcements'"/>
                        <t t-set="config_card" t-value="True"/>
                    </t>
                    <!-- 2. Feedbacks -->
                    <t t-call="portal.portal_docs_entry">
                        <t t-set="icon" t-value="'/community_base/static/src/img/community-feedback.svg'"/>
                        <t t-set="title">Feedbacks</t>
                        <t t-set="text">Submit feedback or check progress</t>
                        <t t-set="url" t-value="'/my/feedbacks'"/>
                        <t t-set="config_card" t-value="True"/>
                    </t>
                    <!-- 3. My Visitors -->
                    <t t-call="portal.portal_docs_entry">
                        <t t-set="icon" t-value="'/community_base/static/src/img/community-visitor.svg'"/>
                        <t t-set="title">My Visitors</t>
                        <t t-set="text">View and manage pending visitors</t>
                        <t t-set="url" t-value="'/my/visitors'"/>
                        <t t-set="config_card" t-value="True"/>
                    </t>
                    <!-- 4. My Appointments -->
                    <t t-call="portal.portal_docs_entry">
                        <t t-set="icon" t-value="'/community_base/static/src/img/community-appointment.svg'"/>
                        <t t-set="title">My Appointments</t>
                        <t t-set="text">Manage visitor appointment passes</t>
                        <t t-set="url" t-value="'/my/appointments'"/>
                        <t t-set="config_card" t-value="True"/>
                    </t>
                    <!-- 5. Parcels -->
                    <t t-call="portal.portal_docs_entry">
                        <t t-set="icon" t-value="'/community_base/static/src/img/community-parcel.svg'"/>
                        <t t-set="title">Parcels</t>
                        <t t-set="text">View pending parcels</t>
                        <t t-set="url" t-value="'/my/parcels'"/>
                        <t t-set="config_card" t-value="True"/>
                    </t>
                    <!-- 6. Storage -->
                    <t t-call="portal.portal_docs_entry">
                        <t t-set="icon" t-value="'/community_base/static/src/img/community-storage.svg'"/>
                        <t t-set="title">Storage</t>
                        <t t-set="text">View storage item status</t>
                        <t t-set="url" t-value="'/my/storage'"/>
                        <t t-set="config_card" t-value="True"/>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Announcement List: portal_table + searchbar + pager           -->
    <!-- ============================================================ -->
    <template id="portal_announcements" name="Announcements">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Announcements</t>
            </t>

            <div t-if="not announcements" class="alert alert-warning" role="alert">
                No announcements available
            </div>
            <t t-if="announcements" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Title</th>
                        <th>Category</th>
                        <th>Publisher</th>
                        <th class="text-end">Published</th>
                    </tr>
                </thead>
                <t t-foreach="announcements" t-as="ann">
                    <tr>
                        <td>
                            <a t-attf-href="/my/announcements/#{ann.id}">
                                <t t-esc="ann.name"/>
                            </a>
                        </td>
                        <td><span class="badge text-bg-light" t-esc="ann.category_id.name"/></td>
                        <td><t t-esc="ann.author_id.name"/></td>
                        <td class="text-end">
                            <span t-field="ann.publish_date" t-options="{'widget': 'date'}"/>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Announcement Detail: portal_sidebar layout                    -->
    <!-- ============================================================ -->
    <template id="portal_announcement_detail" name="Announcement Detail"
              inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <div class="row o_portal_announcement_sidebar">
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-4 col-xxl-3 d-print-none'"/>
                    <t t-set="entries">
                        <div class="d-flex flex-wrap flex-column gap-4">
                            <div class="d-flex align-items-center flex-grow-1 p-0"
                                 t-ignore="true" role="complementary">
                                <ul class="nav flex-column">
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#card_header">Content</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#discussion_section">Discussion</a>
                                    </li>
                                </ul>
                            </div>
                            <div class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">Announcement Info</small></h6>
                                <div t-if="announcement.category_id">
                                    <strong>Category:</strong>
                                    <span t-esc="announcement.category_id.name"/>
                                </div>
                                <div t-if="announcement.office_id">
                                    <strong>Office:</strong>
                                    <span t-esc="announcement.office_id.name"/>
                                </div>
                                <div t-if="announcement.author_id">
                                    <strong>Publisher:</strong>
                                    <span t-esc="announcement.author_id.name"/>
                                </div>
                                <div>
                                    <strong>Published:</strong>
                                    <span t-field="announcement.publish_date"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>

                <div id="announcement_content" class="o_portal_content col-12 col-lg-8 col-xxl-9">
                    <div id="card">
                        <div id="card_header" data-anchor="true">
                            <div class="row justify-content-between mb-3">
                                <div class="col-12 col-md-9">
                                    <h3 class="my-0">
                                        <span t-field="announcement.name"/>
                                    </h3>
                                </div>
                                <div class="col-auto">
                                    <span class="badge text-bg-secondary"
                                          t-esc="announcement.category_id.name"/>
                                </div>
                            </div>
                        </div>
                        <div id="card_body">
                            <div t-field="announcement.content"/>
                        </div>
                    </div>

                    <hr/>
                    <div id="discussion_section" data-anchor="true">
                        <h3>Discussion</h3>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="announcement"/>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Feedback List: portal_table + searchbar + pager                -->
    <!-- ============================================================ -->
    <template id="portal_feedbacks" name="My Feedbacks">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Feedbacks</t>
            </t>

            <div class="d-flex justify-content-end mb-3">
                <a href="/my/feedbacks/new" class="btn btn-primary">
                    <i class="fa fa-plus"/> New Feedback
                </a>
            </div>

            <div t-if="not feedbacks" class="alert alert-warning" role="alert">
                No feedback records
            </div>
            <t t-if="feedbacks" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>No.</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Unit</th>
                        <th class="text-end">Submitted</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <t t-foreach="feedbacks" t-as="fb">
                    <tr>
                        <td>
                            <a t-attf-href="/my/feedbacks/#{fb.id}">
                                <t t-esc="fb.name"/>
                            </a>
                        </td>
                        <td><t t-esc="fb.title"/></td>
                        <td><t t-esc="fb.category_id.name"/></td>
                        <td><t t-esc="fb.unit_id.name"/></td>
                        <td class="text-end">
                            <span t-field="fb.create_date" t-options="{'widget': 'date'}"/>
                        </td>
                        <td class="text-center">
                            <span t-if="fb.state == 'pending'"
                                  class="badge rounded-pill text-bg-warning">Pending</span>
                            <span t-if="fb.state == 'in_progress'"
                                  class="badge rounded-pill text-bg-info">In Progress</span>
                            <span t-if="fb.state == 'done'"
                                  class="badge rounded-pill text-bg-success">Closed</span>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Feedback Detail: portal_sidebar layout                        -->
    <!-- ============================================================ -->
    <template id="portal_feedback_detail" name="Feedback Detail"
              inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <div class="row o_portal_feedback_sidebar">
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-4 col-xxl-3 d-print-none'"/>
                    <t t-set="entries">
                        <div class="d-flex flex-wrap flex-column gap-4">
                            <div class="d-flex align-items-center flex-grow-1 p-0"
                                 t-ignore="true" role="complementary">
                                <ul class="nav flex-column">
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#card_header">Content</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#discussion_section">Discussion</a>
                                    </li>
                                </ul>
                            </div>
                            <div class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">Status</small></h6>
                                <span t-if="feedback.state == 'pending'"
                                      class="badge rounded-pill text-bg-warning">Pending</span>
                                <span t-if="feedback.state == 'in_progress'"
                                      class="badge rounded-pill text-bg-info">In Progress</span>
                                <span t-if="feedback.state == 'done'"
                                      class="badge rounded-pill text-bg-success">Closed</span>
                            </div>
                            <div class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">Feedback Info</small></h6>
                                <div t-if="feedback.category_id">
                                    <strong>Category:</strong>
                                    <span t-esc="feedback.category_id.name"/>
                                </div>
                                <div t-if="feedback.unit_id">
                                    <strong>Unit:</strong>
                                    <span t-esc="feedback.unit_id.name"/>
                                </div>
                                <div>
                                    <strong>Submitted:</strong>
                                    <span t-field="feedback.create_date"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>

                <div id="feedback_content" class="o_portal_content col-12 col-lg-8 col-xxl-9">
                    <div id="card">
                        <div id="card_header" data-anchor="true">
                            <div class="row justify-content-between mb-3">
                                <div class="col-12 col-md-9">
                                    <h3 class="my-0">
                                        <span t-esc="feedback.name"/>
                                        <span class="mx-1">-</span>
                                        <span t-esc="feedback.title"/>
                                    </h3>
                                </div>
                                <div class="col-auto">
                                    <span t-if="feedback.state == 'pending'"
                                          class="badge rounded-pill text-bg-warning">Pending</span>
                                    <span t-if="feedback.state == 'in_progress'"
                                          class="badge rounded-pill text-bg-info">In Progress</span>
                                    <span t-if="feedback.state == 'done'"
                                          class="badge rounded-pill text-bg-success">Closed</span>
                                </div>
                            </div>
                        </div>
                        <div id="card_body">
                            <div class="mb-3">
                                <strong>Content:</strong>
                                <p class="mt-2" style="white-space: pre-wrap;"
                                   t-esc="feedback.content"/>
                            </div>
                        </div>
                    </div>

                    <hr/>
                    <div id="discussion_section" data-anchor="true">
                        <h3>Discussion</h3>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="feedback"/>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- New Feedback Form (kept as card layout)                       -->
    <!-- ============================================================ -->
    <template id="portal_feedback_new" name="New Feedback">
        <t t-call="portal.portal_layout">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">New Feedback</h5>
                </div>
                <div class="card-body">
                    <div t-if="error" class="alert alert-danger" role="alert">
                        <t t-esc="error"/>
                    </div>
                    <p class="text-muted">
                        Dear resident, community maintenance is everyone's responsibility.
                        Any suggestions can be provided to the management committee for reference.
                    </p>
                    <form action="/my/feedbacks/create" method="post">
                        <input type="hidden" name="csrf_token"
                               t-att-value="request.csrf_token()"/>
                        <div class="mb-3">
                            <label class="form-label">Category</label>
                            <select name="category_id" class="form-select"
                                    required="required">
                                <option value="">Select category</option>
                                <t t-foreach="categories" t-as="cat">
                                    <option t-att-value="cat.id"
                                            t-esc="cat.name"/>
                                </t>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Unit</label>
                            <select name="unit_id" class="form-select"
                                    required="required">
                                <option value="">Select unit</option>
                                <t t-foreach="units" t-as="unit">
                                    <option t-att-value="unit.id"
                                            t-esc="unit.name"/>
                                </t>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Title</label>
                            <input type="text" name="title"
                                   class="form-control"
                                   placeholder="Brief summary of your feedback"
                                   required="required"/>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="content" class="form-control"
                                      rows="5"
                                      placeholder="Please describe your feedback or issue in detail..."
                                      required="required"></textarea>
                        </div>
                        <script>
                            document.addEventListener('DOMContentLoaded', function() {
                                document.querySelectorAll('form').forEach(function(form) {
                                    form.addEventListener('submit', function() {
                                        var btn = form.querySelector('button[type="submit"]');
                                        if (btn) {
                                            btn.disabled = true;
                                            btn.textContent = btn.dataset.loadingText || '...';
                                        }
                                    });
                                });
                            });
                        </script>
                        <button type="submit" class="btn btn-primary"
                                data-loading-text="Processing...">
                            <i class="fa fa-paper-plane"/> Submit
                        </button>
                        <a href="/my/feedbacks"
                           class="btn btn-secondary ms-2">Cancel</a>
                    </form>
                </div>
            </div>
        </t>
    </template>

</odoo>
