<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_visit_purpose_form" model="ir.ui.view">
        <field name="name">community.visit.purpose.form</field>
        <field name="model">community.visit.purpose</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_visit_purpose_list" model="ir.ui.view">
        <field name="name">community.visit.purpose.list</field>
        <field name="model">community.visit.purpose</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="action_visit_purpose" model="ir.actions.act_window">
        <field name="name">來訪目的</field>
        <field name="res_model">community.visit.purpose</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
