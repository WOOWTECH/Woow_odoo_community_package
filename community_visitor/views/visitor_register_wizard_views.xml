<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_visitor_register_wizard_form" model="ir.ui.view">
        <field name="name">visitor.register.wizard.form</field>
        <field name="model">visitor.register.wizard</field>
        <field name="arch" type="xml">
            <form string="訪客登記">
                <!-- Blacklist warning -->
                <div class="alert alert-danger" role="alert"
                     invisible="not is_blacklisted">
                    <h4 class="alert-heading">
                        <i class="fa fa-exclamation-triangle"/> 黑名單警告！
                    </h4>
                    <p>此訪客已被列入黑名單。</p>
                    <p>原因：<field name="blacklist_reason" nolabel="1"/></p>
                </div>
                <group string="訪客資訊">
                    <group>
                        <field name="visitor_phone"/>
                        <field name="visitor_name"/>
                        <field name="id_last4"/>
                    </group>
                    <group>
                        <field name="unit_id"/>
                        <field name="purpose"/>
                        <field name="office_id"/>
                    </group>
                </group>
                <group invisible="not purpose_note and purpose != 'other'">
                    <field name="purpose_note"
                           placeholder="請說明來訪目的..."/>
                </group>
                <field name="existing_visitor_id" invisible="1"/>
                <separator string="預約碼驗證"/>
                <group>
                    <field name="access_code"
                           placeholder="輸入6碼驗證碼或掃描 QR Code"/>
                </group>
                <footer>
                    <button name="action_register" type="object"
                            string="登記訪客" class="btn-primary"
                            invisible="is_blacklisted"/>
                    <button name="action_verify_code" type="object"
                            string="驗證預約碼" class="btn-success"
                            invisible="not access_code"/>
                    <button string="取消" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_visitor_register_wizard" model="ir.actions.act_window">
        <field name="name">訪客登記</field>
        <field name="res_model">visitor.register.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
