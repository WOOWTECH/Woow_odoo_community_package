<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_visitor_badge_form" model="ir.ui.view">
        <field name="name">community.visitor.badge.form</field>
        <field name="model">community.visitor.badge</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="state" widget="badge"
                               decoration-success="state == 'available'"
                               decoration-warning="state == 'in_use'"/>
                        <field name="current_visit_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_visitor_badge_list" model="ir.ui.view">
        <field name="name">community.visitor.badge.list</field>
        <field name="model">community.visitor.badge</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-warning="state == 'in_use'"/>
                <field name="current_visit_id"/>
            </list>
        </field>
    </record>

    <record id="action_visitor_badge" model="ir.actions.act_window">
        <field name="name">訪客證管理</field>
        <field name="res_model">community.visitor.badge</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
