<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="cron_visit_timeout_check" model="ir.cron">
        <field name="name">社區訪客：逾時檢查</field>
        <field name="model_id" ref="model_community_visit"/>
        <field name="state">code</field>
        <field name="code">model.action_timeout()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

    <record id="cron_appointment_expiry" model="ir.cron">
        <field name="name">社區訪客：預約過期檢查</field>
        <field name="model_id" ref="model_community_appointment"/>
        <field name="state">code</field>
        <field name="code">model.action_check_expiry()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
    </record>

</odoo>
